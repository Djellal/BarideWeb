@page
@model BarideWeb.Pages.Parameters.IndexModel
@using BarideWeb.Models
@{
    ViewData["Title"] = Model.IsAdmin ? "إعدادات المؤسسات" : "الإعدادات";
}

<div class="card">
    <div class="card-header card-header-custom">
        <h5 class="mb-0"><i class="bi bi-gear-fill"></i> @(Model.IsAdmin ? "إعدادات المؤسسات" : "الإعدادات")</h5>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert alert-info py-2">@Model.StatusMessage</div>
        }

        <div class="accordion" id="tenantAccordion">
            @foreach (var tp in Model.TenantParams)
            {
                var collapseId = "collapse-" + tp.TenantId.ToString("N");
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button"
                                data-bs-toggle="collapse" data-bs-target="#@collapseId">
                            <i class="bi bi-building me-2"></i> @tp.TenantName
                        </button>
                    </h2>
                    <div id="@collapseId" class="accordion-collapse collapse" data-bs-parent="#tenantAccordion">
                        <div class="accordion-body">
                            <form method="post" asp-page-handler="Save">
                                <input type="hidden" name="tenantId" value="@tp.TenantId" />

                                @foreach (var p in tp.Parameters)
                                {
                                    @if (p.Key == "EmailTemplate") { continue; }
                                    <div class="row mb-3 align-items-center">
                                        @if (p.Key == "CorrespViewMode")
                                        {
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold">
                                                    <i class="bi bi-eye"></i> طريقة عرض المراسلة
                                                </label>
                                                <p class="text-muted small mb-0">@p.Description</p>
                                            </div>
                                            <div class="col-md-5">
                                                <select name="param[CorrespViewMode]" class="form-select">
                                                    <option value="0" selected="@(p.Value == "0")">
                                                        <i class="bi bi-box-arrow-up-right"></i> فتح في صفحة جديدة
                                                    </option>
                                                    <option value="1" selected="@(p.Value == "1")">
                                                        <i class="bi bi-window"></i> فتح في نافذة منبثقة
                                                    </option>
                                                    <option value="2" selected="@(p.Value == "2")">
                                                        <i class="bi bi-arrow-right"></i> فتح في نفس الصفحة
                                                    </option>
                                                </select>
                                            </div>
                                        }
                                        else if (p.Key == "ScannerDpi")
                                        {
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold">
                                                    <i class="bi bi-speedometer2"></i> دقة المسح الضوئي (DPI)
                                                </label>
                                                <p class="text-muted small mb-0">@p.Description</p>
                                            </div>
                                            <div class="col-md-5">
                                                <select name="param[ScannerDpi]" class="form-select">
                                                    <option value="100" selected="@(p.Value == "100")">100</option>
                                                    <option value="150" selected="@(p.Value == "150")">150</option>
                                                    <option value="200" selected="@(p.Value == "200")">200</option>
                                                    <option value="300" selected="@(p.Value == "300")">300</option>
                                                    <option value="600" selected="@(p.Value == "600")">600</option>
                                                </select>
                                            </div>
                                        }
                                        else if (p.Key == "ScannerPixelMode")
                                        {
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold">
                                                    <i class="bi bi-palette"></i> وضع اللون الافتراضي
                                                </label>
                                                <p class="text-muted small mb-0">@p.Description</p>
                                            </div>
                                            <div class="col-md-5">
                                                <select name="param[ScannerPixelMode]" class="form-select">
                                                    <option value="Color" selected="@(p.Value == "Color")">ألوان</option>
                                                    <option value="Grayscale" selected="@(p.Value == "Grayscale")">رمادي</option>
                                                </select>
                                            </div>
                                        }
                                        else if (p.Key == "ScannerImageFormat")
                                        {
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold">
                                                    <i class="bi bi-file-image"></i> صيغة الصورة الافتراضية
                                                </label>
                                                <p class="text-muted small mb-0">@p.Description</p>
                                            </div>
                                            <div class="col-md-5">
                                                <select name="param[ScannerImageFormat]" class="form-select">
                                                    <option value="JPG" selected="@(p.Value == "JPG")">JPG</option>
                                                    <option value="PNG" selected="@(p.Value == "PNG")">PNG</option>
                                                    <option value="PDF" selected="@(p.Value == "PDF")">PDF</option>
                                                </select>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="col-md-4">
                                                <label class="form-label fw-bold">@p.Key</label>
                                                @if (!string.IsNullOrEmpty(p.Description))
                                                {
                                                    <p class="text-muted small mb-0">@p.Description</p>
                                                }
                                            </div>
                                            <div class="col-md-5">
                                                <input type="text" name="param[@p.Key]" value="@p.Value" class="form-control" />
                                            </div>
                                        }
                                    </div>
                                }

                                <div class="text-end">
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="bi bi-check-circle"></i> حفظ إعدادات @tp.TenantName
                                    </button>
                                </div>
                            </form>

                            @{
                                var emailParam = tp.Parameters.FirstOrDefault(p => p.Key == "EmailTemplate");
                                var templateContent = emailParam?.LongValue ?? "";
                                var tenantIdStr = tp.TenantId.ToString("N");
                            }
                            <hr class="my-4" />
                            <div class="mb-3">
                                <h6 class="fw-bold"><i class="bi bi-envelope-paper"></i> قالب البريد الإلكتروني</h6>
                                <p class="text-muted small">
                                    يمكنك تعديل قالب البريد الإلكتروني المرسل عند مشاركة المراسلات. استخدم المتغيرات التالية:
                                </p>
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <span class="badge bg-primary">@("{{Num}}")</span>
                                    <span class="badge bg-primary">@("{{NumInterne}}")</span>
                                    <span class="badge bg-primary">@("{{Objet}}")</span>
                                    <span class="badge bg-primary">@("{{Expediteur}}")</span>
                                    <span class="badge bg-primary">@("{{DateCorresp}}")</span>
                                    <span class="badge bg-primary">@("{{DateArrivDepart}}")</span>
                                    <span class="badge bg-primary">@("{{Observation}}")</span>
                                    <span class="badge bg-secondary">@("{{TypeLabel}}")</span>
                                    <span class="badge bg-secondary">@("{{ExpedLabel}}")</span>
                                    <span class="badge bg-secondary">@("{{ObservationRow}}")</span>
                                    <span class="badge bg-secondary">@("{{NumInterneRow}}")</span>
                                    <span class="badge bg-success">@("{{ViewUrl}}")</span>
                                </div>
                            </div>

                            <form method="post" asp-page-handler="SaveEmailTemplate">
                                <input type="hidden" name="tenantId" value="@tp.TenantId" />

                                <ul class="nav nav-tabs mb-0" role="tablist">
                                    <li class="nav-item">
                                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#editor-@tenantIdStr" type="button">
                                            <i class="bi bi-code-slash"></i> تحرير القالب
                                        </button>
                                    </li>
                                    <li class="nav-item">
                                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#preview-@tenantIdStr" type="button"
                                                onclick="updatePreview_@(tenantIdStr)()">
                                            <i class="bi bi-eye"></i> معاينة
                                        </button>
                                    </li>
                                </ul>

                                <div class="tab-content border border-top-0 rounded-bottom">
                                    <div class="tab-pane fade show active p-0" id="editor-@tenantIdStr">
                                        <textarea name="emailTemplate" id="emailTemplateEditor-@tenantIdStr"
                                                  class="form-control font-monospace border-0 rounded-0"
                                                  style="min-height:400px;font-size:13px;resize:vertical;direction:ltr;text-align:left;"
                                                  >@templateContent</textarea>
                                    </div>
                                    <div class="tab-pane fade" id="preview-@tenantIdStr">
                                        <iframe id="emailPreview-@tenantIdStr" style="width:100%;min-height:500px;border:none;background:#eef2f7;"></iframe>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between mt-3">
                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                            onclick="resetTemplate_@(tenantIdStr)()">
                                        <i class="bi bi-arrow-counterclockwise"></i> استعادة القالب الافتراضي
                                    </button>
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="bi bi-check-circle"></i> حفظ قالب البريد
                                    </button>
                                </div>
                            </form>

                            <script>
                                function updatePreview_@(tenantIdStr)() {
                                    var html = document.getElementById('emailTemplateEditor-@tenantIdStr').value;
                                    // Replace placeholders with sample data for preview
                                    html = html.replace(/\{\{Num\}\}/g, '2025/123')
                                        .replace(/\{\{NumInterne\}\}/g, 'INT-456')
                                        .replace(/\{\{Objet\}\}/g, 'موضوع تجريبي للمعاينة')
                                        .replace(/\{\{Expediteur\}\}/g, 'المديرية الفرعية')
                                        .replace(/\{\{DateCorresp\}\}/g, '2025/03/15')
                                        .replace(/\{\{DateArrivDepart\}\}/g, '2025/03/16')
                                        .replace(/\{\{Observation\}\}/g, 'ملاحظة تجريبية')
                                        .replace(/\{\{TypeLabel\}\}/g, 'وارد داخلي')
                                        .replace(/\{\{ExpedLabel\}\}/g, 'المرسل')
                                        .replace(/\{\{ViewUrl\}\}/g, '#')
                                        .replace(/\{\{NumInterneRow\}\}/g, "<p style='margin:6px 0 0;font-size:13px;color:#94a3b8;'>الرقم الداخلي: INT-456</p>")
                                        .replace(/\{\{ObservationRow\}\}/g, "<tr><td style='padding:14px 20px;font-size:14px;color:#6b7280;border-bottom:1px solid #f0f0f0;width:130px;font-weight:600;'>ملاحظة</td><td style='padding:14px 20px;font-size:14px;color:#374151;border-bottom:1px solid #f0f0f0;'>ملاحظة تجريبية</td></tr>");
                                    var iframe = document.getElementById('emailPreview-@tenantIdStr');
                                    iframe.srcdoc = html;
                                }
                                function resetTemplate_@(tenantIdStr)() {
                                    if (!confirm('هل تريد استعادة القالب الافتراضي؟ سيتم فقد التعديلات الحالية.')) return;
                                    fetch('?handler=DefaultEmailTemplate')
                                        .then(r => r.text())
                                        .then(html => {
                                            document.getElementById('emailTemplateEditor-@tenantIdStr').value = html;
                                        });
                                }
                            </script>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
