@page
@model IndexModel
@using BarideWeb.Models
@{
    ViewData["Title"] = "الرئيسية";
}

<div class="card" data-aos="fade-up">
    <div class="card-header card-header-custom d-flex justify-content-between align-items-center flex-wrap">
        <div class="d-flex gap-2 flex-wrap align-items-center">
            @if (User.IsInRole("Admin") || User.IsInRole("TenantAdmin"))
            {
                <!-- Add dropdown -->
                <div class="dropdown">
                    <button class="btn btn-success btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-plus-circle"></i> إضافـــة
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" asp-page="/Correspondances/Create" asp-route-type="0">وارد داخلي</a></li>
                        <li><a class="dropdown-item" asp-page="/Correspondances/Create" asp-route-type="1">وارد خارجي</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><a class="dropdown-item" asp-page="/Correspondances/Create" asp-route-type="2">صادر داخلي</a></li>
                        <li><a class="dropdown-item" asp-page="/Correspondances/Create" asp-route-type="3">صادر خارجي</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><a class="dropdown-item" asp-page="/Correspondances/Create" asp-route-type="4">متفرقات</a></li>
                    </ul>
                </div>
            }

            <!-- Print -->
            <a class="btn btn-info btn-sm text-white" asp-page="/Correspondances/Print" asp-route-type="@((int)Model.CurrentType)">
                <i class="bi bi-printer"></i> طباعة
            </a>
        </div>

        <!-- Search -->
        <form method="get" class="d-flex gap-2 align-items-center mt-2 mt-lg-0">
            <input type="text" name="search" value="@Model.SearchText" class="form-control form-control-sm search-box" placeholder="بحث في كل المراسلات..." />
            <button type="submit" class="btn btn-light btn-sm"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(Model.SearchText))
            {
                <a class="btn btn-outline-light btn-sm" asp-page="/Index" asp-route-type="@((int)Model.CurrentType)">
                    <i class="bi bi-x-circle"></i>
                </a>
            }
        </form>
    </div>

    <div class="card-body p-0">
        <!-- Type tabs -->
        <ul class="nav nav-tabs type-tabs px-2 pt-2">
            <li class="nav-item">
                <a class="nav-link @(Model.CurrentType == TypeCorresp.Entrant_Interne ? "active" : "")"
                   asp-page="/Index" asp-route-type="0">وارد داخلي</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.CurrentType == TypeCorresp.Entrant_Externe ? "active" : "")"
                   asp-page="/Index" asp-route-type="1">وارد خارجي</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.CurrentType == TypeCorresp.Sotant_Interne ? "active" : "")"
                   asp-page="/Index" asp-route-type="2">صادر داخلي</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.CurrentType == TypeCorresp.Sortant_Externe ? "active" : "")"
                   asp-page="/Index" asp-route-type="3">صادر خارجي</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.CurrentType == TypeCorresp.Divers ? "active" : "")"
                   asp-page="/Index" asp-route-type="4">متفرقات</a>
            </li>
        </ul>

        <!-- Advanced filter toggle -->
        <div class="px-3 pt-2">
            <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#filterPanel">
                <i class="bi bi-funnel"></i> فرز المراسلات
            </button>
        </div>

        <!-- Advanced filter panel -->
        <div class="collapse px-3 pt-2" id="filterPanel">
            <form method="get" class="card card-body bg-light">
                <input type="hidden" name="type" value="@((int)Model.CurrentType)" />
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">الصنف</label>
                        <select name="catId" class="form-select form-select-sm">
                            <option value="">-- الكل --</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.CatId" selected="@(Model.FilterCatId == cat.CatId)">@cat.Designation</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">@Model.ExpedLabel</label>
                        <input type="text" name="exped" value="@Model.FilterExped" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">الموضوع</label>
                        <input type="text" name="objet" value="@Model.FilterObjet" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">من تاريخ</label>
                        <input type="date" name="dateFrom" value="@Model.FilterDateFrom?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">إلى تاريخ</label>
                        <input type="date" name="dateTo" value="@Model.FilterDateTo?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-funnel-fill"></i> فرز</button>
                        <a class="btn btn-secondary btn-sm" asp-page="/Index" asp-route-type="@((int)Model.CurrentType)">إلغاء</a>
                    </div>
                </div>
            </form>
        </div>

        <!-- AG Grid -->
        <div id="correspGrid" class="ag-theme-alpine mt-2" style="width: 100%; height: 500px;"></div>

        <!-- Delete confirmation modal (shared) -->
        <div class="modal fade" id="deleteModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">تأكيد الحذف</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        هل تريد فعلا حذف هذه المراسلة ؟
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">لا</button>
                        <form method="post" asp-page-handler="Delete">
                            <input type="hidden" name="id" id="deleteId" />
                            <input type="hidden" name="type" value="@((int)Model.CurrentType)" />
                            <button type="submit" class="btn btn-danger">نعم، حذف</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="status-bar">
        عدد المراسلات: <span id="totalCount">0</span>
    </div>
</div>

@if (Model.CorrespViewMode == ViewMode.Modal)
{
    <!-- View modal -->
    <div class="modal fade" id="viewModal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">عرض المراسلة</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="viewModalBody">
                    <div class="text-center py-5">
                        <div class="spinner-border" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Transfer modal -->
<div class="modal fade" id="transferModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Transfer">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-send"></i> تحويل المراسلة</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="cid" id="transferCid" />
                    <div class="mb-3">
                        <label class="form-label">المرسل إليهم</label>
                        <select id="transferUserSelect" name="receiverIds" multiple placeholder="اكتب اسم المستخدم..."></select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">ملاحظة</label>
                        <textarea name="note" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-info text-white">تحويل</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Share modal -->
<div class="modal fade" id="shareModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Share" id="shareForm">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-share"></i> إرسال رابط المراسلة</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="cid" id="shareCid" />
                    <input type="hidden" name="contactsJson" id="contactsJsonInput" />
                    <div class="mb-3">
                        <label class="form-label">جهات الاتصال</label>
                        <select id="shareContactSelect" multiple placeholder="اكتب الاسم أو البريد..."></select>
                        <small class="text-muted">اكتب بريد إلكتروني جديد واضغط Enter لإضافته</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-envelope"></i> إرسال
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function selectDocument(el, url) {
            var container = el.closest('.row');
            container.querySelectorAll('.doc-item').forEach(function (item) {
                item.classList.remove('active');
            });
            el.classList.add('active');
            var viewer = container.querySelector('.doc-preview');
            if (!viewer) return;
            var ext = url.split('.').pop().toLowerCase();
            if (ext === 'pdf') {
                viewer.innerHTML = '<iframe src="' + url + '" width="100%" height="100%" style="min-height:400px; border:none;"></iframe>';
            } else if (['jpg', 'jpeg', 'png', 'gif', 'bmp', 'webp'].indexOf(ext) >= 0) {
                viewer.innerHTML = '<div class="p-3 text-center"><img src="' + url + '" class="img-fluid rounded shadow-sm" style="max-height:500px;" /></div>';
            } else {
                viewer.innerHTML = '<div class="text-center p-4"><i class="bi bi-file-earmark-arrow-down" style="font-size:3rem; color:var(--primary);"></i>'
                    + '<p class="mt-2">لا يمكن معاينة هذا الملف</p>'
                    + '<a href="' + url + '" target="_blank" class="btn btn-primary btn-sm"><i class="bi bi-download"></i> تحميل الملف</a></div>';
            }
        }

        function loadViewModal(cid) {
            var modal = new bootstrap.Modal(document.getElementById('viewModal'));
            var body = document.getElementById('viewModalBody');
            body.innerHTML = '<div class="text-center py-5"><div class="spinner-border" role="status"></div></div>';
            modal.show();
            fetch('?handler=ViewPartial&id=' + cid)
                .then(function (r) { return r.text(); })
                .then(function (html) {
                    body.innerHTML = html;
                    var first = body.querySelector('.doc-list .doc-item[onclick]');
                    if (first) first.click();
                });
        }

        function confirmDelete(cid) {
            document.getElementById('deleteId').value = cid;
            var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }

        var viewMode = @((int)Model.CorrespViewMode);
        var searchText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SearchText ?? ""));
        var searchAll = @(Model.SearchAll ? "true" : "false");
        var canEdit = @(User.IsInRole("Admin") || User.IsInRole("TenantAdmin") ? "true" : "false");
        var currentType = @((int)Model.CurrentType);
        var filterCatId = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FilterCatId?.ToString() ?? ""));
        var filterExped = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FilterExped ?? ""));
        var filterObjet = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FilterObjet ?? ""));
        var filterDateFrom = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FilterDateFrom?.ToString("yyyy-MM-dd") ?? ""));
        var filterDateTo = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FilterDateTo?.ToString("yyyy-MM-dd") ?? ""));

        var columnDefs = [
            { field: 'num', headerName: 'الرقم', sortable: true, minWidth: 100 },
            { field: 'numInterne', headerName: 'الرقم الداخلي', sortable: true, minWidth: 120 },
            { field: 'dateCorresp', headerName: 'تاريخ المراسلة', sortable: true, minWidth: 130 },
            { field: 'dateArrivDepart', headerName: 'تاريخ الوصول', sortable: true, minWidth: 130 },
            { field: 'expediteur', headerName: 'المرسل', sortable: true, minWidth: 150, flex: 1 },
            { field: 'objet', headerName: 'الموضوع', sortable: true, minWidth: 200, flex: 2 },
            { field: 'observation', headerName: 'ملاحظة', sortable: true, minWidth: 130 },
            { field: 'categorie', headerName: 'الصنف', sortable: true, minWidth: 120 }
        ];

        if (searchAll) {
            columnDefs.push({ field: 'typeLabel', headerName: 'النوع', sortable: true, minWidth: 110 });
        }

        columnDefs.push({
            headerName: 'التحويلات',
            minWidth: 90,
            sortable: false,
            cellRenderer: function (params) {
                if (!params.data) return '';
                if (params.data.transfertCount > 0) {
                    return '<a href="/Transferts?cid=' + params.data.cid + '" class="badge bg-info text-white text-decoration-none" title="عرض التحويلات"><i class="bi bi-send"></i> ' + params.data.transfertCount + '</a>';
                }
                return '<span class="text-muted">-</span>';
            }
        });

        columnDefs.push({
            headerName: 'الإجراءات',
            minWidth: canEdit ? 140 : 60,
            sortable: false,
            cellRenderer: function (params) {
                if (!params.data) return '';
                var viewUrl = '/Correspondances/View?id=' + params.data.cid;
                var editUrl = '/Correspondances/Edit?id=' + params.data.cid;
                var html = '<div class="btn-group btn-group-sm">'
                    + '<a class="btn btn-outline-primary" href="' + viewUrl + '" title="عرض"><i class="bi bi-eye"></i></a>';
                if (canEdit) {
                    html += '<a class="btn btn-outline-warning" href="' + editUrl + '" title="تعديل"><i class="bi bi-pencil"></i></a>'
                        + '<button type="button" class="btn btn-outline-danger" onclick="confirmDelete(\'' + params.data.cid + '\')" title="حذف"><i class="bi bi-trash"></i></button>';
                }
                html += '</div>';
                return html;
            }
        });

        var dataSource = {
            getRows: function (params) {
                var sortField = '';
                var sortDir = '';
                if (params.sortModel && params.sortModel.length > 0) {
                    sortField = params.sortModel[0].colId;
                    sortDir = params.sortModel[0].sort;
                }

                var url = '/api/correspondances?startRow=' + params.startRow + '&endRow=' + params.endRow
                    + '&type=' + currentType;
                if (searchText) url += '&search=' + encodeURIComponent(searchText);
                if (filterCatId) url += '&catId=' + filterCatId;
                if (filterExped) url += '&exped=' + encodeURIComponent(filterExped);
                if (filterObjet) url += '&objet=' + encodeURIComponent(filterObjet);
                if (filterDateFrom) url += '&dateFrom=' + filterDateFrom;
                if (filterDateTo) url += '&dateTo=' + filterDateTo;
                if (sortField) url += '&sortField=' + sortField + '&sortDir=' + sortDir;

                fetch(url)
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        document.getElementById('totalCount').textContent = data.totalCount;
                        var lastRow = data.totalCount <= params.endRow ? data.totalCount : -1;
                        params.successCallback(data.rows, lastRow);
                    })
                    .catch(function () {
                        params.failCallback();
                    });
            }
        };

        var gridOptions = {
            columnDefs: columnDefs,
            defaultColDef: { resizable: true },
            rowModelType: 'infinite',
            datasource: dataSource,
            cacheBlockSize: 50,
            maxBlocksInCache: 10,
            enableRtl: true,
            animateRows: true,
            rowSelection: 'single',
            overlayNoRowsTemplate: '<div class="text-center text-muted py-5"><i class="bi bi-inbox" style="font-size: 2.5rem; opacity: 0.3;"></i><p class="mt-2 mb-0">لا توجد مراسلات</p></div>',
            onRowClicked: function (event) {
                if (!event.data || event.event.target.closest('.btn-group')) return;
                var cid = event.data.cid;
                var viewUrl = '/Correspondances/View?id=' + cid;
                if (viewMode === 1) {
                    loadViewModal(cid);
                } else if (viewMode === 0) {
                    window.open(viewUrl, '_blank');
                } else {
                    window.location.href = viewUrl;
                }
            }
        };

        var gridDiv = document.getElementById('correspGrid');
        new agGrid.Grid(gridDiv, gridOptions);

        document.getElementById('transferModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            if (btn) {
                var cidInput = btn.closest('[data-corresp-cid]');
                if (cidInput) document.getElementById('transferCid').value = cidInput.dataset.correspCid;
            }
        });
        document.getElementById('shareModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            if (btn) {
                var cidInput = btn.closest('[data-corresp-cid]');
                if (cidInput) document.getElementById('shareCid').value = cidInput.dataset.correspCid;
            }
        });

        new TomSelect('#transferUserSelect', {
            valueField: 'id',
            labelField: 'fullName',
            searchField: ['fullName', 'userName'],
            plugins: ['remove_button'],
            load: function (query, callback) {
                if (query.length < 2) return callback();
                fetch('/api/users/search?q=' + encodeURIComponent(query))
                    .then(function (r) { return r.json(); })
                    .then(function (data) { callback(data); })
                    .catch(function () { callback(); });
            },
            render: {
                option: function (item) {
                    return '<div>' + item.fullName + ' <small class="text-muted">(' + item.userName + ')</small></div>';
                },
                item: function (item) {
                    return '<div>' + item.fullName + ' (' + item.userName + ')</div>';
                }
            }
        });

        var shareSelect = new TomSelect('#shareContactSelect', {
            valueField: 'email',
            labelField: 'name',
            searchField: ['name', 'email'],
            plugins: ['remove_button'],
            create: function (input) {
                return { name: input, email: input, phone: '' };
            },
            load: function (query, callback) {
                if (query.length < 2) return callback();
                fetch('/api/contacts/search?q=' + encodeURIComponent(query))
                    .then(function (r) { return r.json(); })
                    .then(function (data) { callback(data); })
                    .catch(function () { callback(); });
            },
            render: {
                option: function (item) {
                    return '<div>' + item.name + ' <small class="text-muted">' + item.email + '</small></div>';
                },
                item: function (item) {
                    return '<div>' + item.name + ' (' + item.email + ')</div>';
                }
            },
            onItemAdd: function () { updateContactsJson(); },
            onItemRemove: function () { updateContactsJson(); }
        });

        function updateContactsJson() {
            var items = shareSelect.items.map(function (email) {
                var opt = shareSelect.options[email];
                return { name: opt.name || email, email: email, phone: opt.phone || '' };
            });
            document.getElementById('contactsJsonInput').value = JSON.stringify(items);
        }
    </script>
}
