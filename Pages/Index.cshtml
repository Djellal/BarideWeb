@page
@model IndexModel
@using BarideWeb.Models
@{
    ViewData["Title"] = "الرئيسية";
}

<div class="card">
    <div class="card-header card-header-custom d-flex justify-content-between align-items-center flex-wrap">
        <div class="d-flex gap-2 flex-wrap align-items-center">
            @if (User.IsInRole("Admin") || User.IsInRole("TenantAdmin"))
            {
                <!-- Add dropdown -->
                <div class="dropdown">
                    <button class="btn btn-success btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-plus-circle"></i> إضافـــة
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" asp-page="/Correspondances/Create" asp-route-type="0">وارد داخلي</a></li>
                        <li><a class="dropdown-item" asp-page="/Correspondances/Create" asp-route-type="1">وارد خارجي</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><a class="dropdown-item" asp-page="/Correspondances/Create" asp-route-type="2">صادر داخلي</a></li>
                        <li><a class="dropdown-item" asp-page="/Correspondances/Create" asp-route-type="3">صادر خارجي</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><a class="dropdown-item" asp-page="/Correspondances/Create" asp-route-type="4">متفرقات</a></li>
                    </ul>
                </div>
            }

            <!-- Print -->
            <a class="btn btn-info btn-sm text-white" asp-page="/Correspondances/Print" asp-route-type="@((int)Model.CurrentType)">
                <i class="bi bi-printer"></i> طباعة
            </a>
        </div>

        <!-- Search -->
        <form method="get" class="d-flex gap-2 align-items-center mt-2 mt-lg-0">
            <input type="text" name="search" value="@Model.SearchText" class="form-control form-control-sm search-box" placeholder="بحث في كل المراسلات..." />
            <button type="submit" class="btn btn-light btn-sm"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(Model.SearchText))
            {
                <a class="btn btn-outline-light btn-sm" asp-page="/Index" asp-route-type="@((int)Model.CurrentType)">
                    <i class="bi bi-x-circle"></i>
                </a>
            }
        </form>
    </div>

    <div class="card-body p-0">
        <!-- Type tabs -->
        <ul class="nav nav-tabs type-tabs px-2 pt-2">
            <li class="nav-item">
                <a class="nav-link @(Model.CurrentType == TypeCorresp.Entrant_Interne ? "active" : "")"
                   asp-page="/Index" asp-route-type="0">وارد داخلي</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.CurrentType == TypeCorresp.Entrant_Externe ? "active" : "")"
                   asp-page="/Index" asp-route-type="1">وارد خارجي</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.CurrentType == TypeCorresp.Sotant_Interne ? "active" : "")"
                   asp-page="/Index" asp-route-type="2">صادر داخلي</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.CurrentType == TypeCorresp.Sortant_Externe ? "active" : "")"
                   asp-page="/Index" asp-route-type="3">صادر خارجي</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(Model.CurrentType == TypeCorresp.Divers ? "active" : "")"
                   asp-page="/Index" asp-route-type="4">متفرقات</a>
            </li>
        </ul>

        <!-- Advanced filter toggle -->
        <div class="px-3 pt-2">
            <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#filterPanel">
                <i class="bi bi-funnel"></i> فرز المراسلات
            </button>
        </div>

        <!-- Advanced filter panel -->
        <div class="collapse px-3 pt-2" id="filterPanel">
            <form method="get" class="card card-body bg-light">
                <input type="hidden" name="type" value="@((int)Model.CurrentType)" />
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">الصنف</label>
                        <select name="catId" class="form-select form-select-sm">
                            <option value="">-- الكل --</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.CatId" selected="@(Model.FilterCatId == cat.CatId)">@cat.Designation</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">@Model.ExpedLabel</label>
                        <input type="text" name="exped" value="@Model.FilterExped" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">الموضوع</label>
                        <input type="text" name="objet" value="@Model.FilterObjet" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">من تاريخ</label>
                        <input type="date" name="dateFrom" value="@Model.FilterDateFrom?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">إلى تاريخ</label>
                        <input type="date" name="dateTo" value="@Model.FilterDateTo?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-funnel-fill"></i> فرز</button>
                        <a class="btn btn-secondary btn-sm" asp-page="/Index" asp-route-type="@((int)Model.CurrentType)">إلغاء</a>
                    </div>
                </div>
            </form>
        </div>

        <!-- AG Grid -->
        <div id="correspGrid" class="ag-theme-alpine mt-2" style="width: 100%; height: 500px;"></div>

        <!-- Delete confirmation modal (shared) -->
        <div class="modal fade" id="deleteModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">تأكيد الحذف</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        هل تريد فعلا حذف هذه المراسلة ؟
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">لا</button>
                        <form method="post" asp-page-handler="Delete">
                            <input type="hidden" name="id" id="deleteId" />
                            <input type="hidden" name="type" value="@((int)Model.CurrentType)" />
                            <button type="submit" class="btn btn-danger">نعم، حذف</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="status-bar">
        عدد المراسلات: @Model.Correspondances.Count
    </div>
</div>

@if (Model.CorrespViewMode == ViewMode.Modal)
{
    <!-- View modal -->
    <div class="modal fade" id="viewModal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">عرض المراسلة</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="viewModalBody">
                    <div class="text-center py-5">
                        <div class="spinner-border" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Transfer modal -->
<div class="modal fade" id="transferModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Transfer">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-send"></i> تحويل المراسلة</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="cid" id="transferCid" />
                    <div class="mb-3">
                        <label class="form-label">المرسل إليه</label>
                        <select name="receiverId" class="form-select" required>
                            <option value="">-- اختر مستخدم --</option>
                            @foreach (var user in Model.Users)
                            {
                                <option value="@user.Id">@user.FullName (@user.UserName)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">ملاحظة</label>
                        <textarea name="note" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-info text-white">تحويل</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Share modal -->
<div class="modal fade" id="shareModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Share" id="shareForm">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-share"></i> إرسال رابط المراسلة</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="cid" id="shareCid" />
                    <input type="hidden" name="contactsJson" id="contactsJsonInput" />

                    <div class="mb-3 position-relative">
                        <label class="form-label">بحث عن جهة اتصال</label>
                        <input type="text" id="contactSearch" class="form-control" placeholder="اكتب الاسم أو البريد..." autocomplete="off" />
                        <div id="contactSuggestions" class="list-group position-absolute w-100" style="z-index:1050; display:none;"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">أو أضف جهة اتصال جديدة</label>
                        <div class="row g-2">
                            <div class="col-md-4">
                                <input type="text" id="newContactName" class="form-control form-control-sm" placeholder="الاسم" />
                            </div>
                            <div class="col-md-4">
                                <input type="email" id="newContactEmail" class="form-control form-control-sm" placeholder="البريد الإلكتروني" />
                            </div>
                            <div class="col-md-2">
                                <input type="text" id="newContactPhone" class="form-control form-control-sm" placeholder="الهاتف" />
                            </div>
                            <div class="col-md-2">
                                <button type="button" id="addContactBtn" class="btn btn-sm btn-outline-success w-100">
                                    <i class="bi bi-plus"></i> إضافة
                                </button>
                            </div>
                        </div>
                    </div>

                    <div id="selectedContacts">
                        <label class="form-label">جهات الاتصال المختارة</label>
                        <div id="contactsList" class="d-flex flex-wrap gap-2"></div>
                        <p id="noContactsMsg" class="text-muted small">لم يتم اختيار أي جهة اتصال</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-success" id="shareSubmitBtn" disabled>
                        <i class="bi bi-envelope"></i> إرسال
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function selectDocument(el, url) {
            var container = el.closest('.row');
            container.querySelectorAll('.doc-item').forEach(function (item) {
                item.classList.remove('active');
            });
            el.classList.add('active');

            var viewer = container.querySelector('.doc-preview');
            if (!viewer) return;
            var ext = url.split('.').pop().toLowerCase();
            if (ext === 'pdf') {
                viewer.innerHTML = '<iframe src="' + url + '" width="100%" height="100%" style="min-height:400px; border:none;"></iframe>';
            } else if (['jpg', 'jpeg', 'png', 'gif', 'bmp', 'webp'].indexOf(ext) >= 0) {
                viewer.innerHTML = '<div class="p-3 text-center"><img src="' + url + '" class="img-fluid rounded shadow-sm" style="max-height:500px;" /></div>';
            } else {
                viewer.innerHTML = '<div class="text-center p-4"><i class="bi bi-file-earmark-arrow-down" style="font-size:3rem; color:var(--primary);"></i>'
                    + '<p class="mt-2">لا يمكن معاينة هذا الملف</p>'
                    + '<a href="' + url + '" target="_blank" class="btn btn-primary btn-sm"><i class="bi bi-download"></i> تحميل الملف</a></div>';
            }
        }

        function loadViewModal(cid) {
            var modal = new bootstrap.Modal(document.getElementById('viewModal'));
            var body = document.getElementById('viewModalBody');
            body.innerHTML = '<div class="text-center py-5"><div class="spinner-border" role="status"></div></div>';
            modal.show();
            fetch('?handler=ViewPartial&id=' + cid)
                .then(function (r) { return r.text(); })
                .then(function (html) {
                    body.innerHTML = html;
                });
        }

        function confirmDelete(cid) {
            document.getElementById('deleteId').value = cid;
            var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }

        var viewMode = @((int)Model.CorrespViewMode);
        var searchAll = @(Model.SearchAll ? "true" : "false");
        var canEdit = @(User.IsInRole("Admin") || User.IsInRole("TenantAdmin") ? "true" : "false");

        var rowData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Correspondances.Select(c => new {
            cid = c.Cid,
            num = c.Num,
            numInterne = c.NumInterne,
            dateCorresp = c.DateCorresp.ToString("yyyy-MM-dd"),
            dateArrivDepart = c.DateArrivDepart.ToString("yyyy-MM-dd"),
            expediteur = c.Expediteur,
            objet = c.Objet,
            observation = c.Observation ?? "",
            categorie = c.Categ != null ? c.Categ.Designation : "",
            typeLabel = c.Type switch {
                TypeCorresp.Entrant_Interne => "وارد داخلي",
                TypeCorresp.Entrant_Externe => "وارد خارجي",
                TypeCorresp.Sotant_Interne => "صادر داخلي",
                TypeCorresp.Sortant_Externe => "صادر خارجي",
                TypeCorresp.Divers => "متفرقات",
                _ => ""
            },
            viewUrl = Url.Page("/Correspondances/View", new { id = c.Cid }),
            editUrl = Url.Page("/Correspondances/Edit", new { id = c.Cid }),
            transfertCount = Model.TransfertCounts.GetValueOrDefault(c.Cid, 0),
            transfertUrl = Url.Page("/Transferts/Index", new { cid = c.Cid })
        })));

        var columnDefs = [
            { field: 'num', headerName: 'الرقم', filter: true, sortable: true, minWidth: 100 },
            { field: 'numInterne', headerName: 'الرقم الداخلي', filter: true, sortable: true, minWidth: 120 },
            { field: 'dateCorresp', headerName: 'تاريخ المراسلة', filter: 'agDateColumnFilter', sortable: true, minWidth: 130 },
            { field: 'dateArrivDepart', headerName: 'تاريخ الوصول', filter: 'agDateColumnFilter', sortable: true, minWidth: 130 },
            { field: 'expediteur', headerName: 'المرسل', filter: true, sortable: true, minWidth: 150, flex: 1 },
            { field: 'objet', headerName: 'الموضوع', filter: true, sortable: true, minWidth: 200, flex: 2 },
            { field: 'observation', headerName: 'ملاحظة', filter: true, sortable: true, minWidth: 130 },
            { field: 'categorie', headerName: 'الصنف', filter: true, sortable: true, minWidth: 120 }
        ];

        if (searchAll) {
            columnDefs.push({ field: 'typeLabel', headerName: 'النوع', filter: true, sortable: true, minWidth: 110 });
        }

        columnDefs.push({
            headerName: 'التحويلات',
            minWidth: 90,
            sortable: true,
            filter: false,
            cellRenderer: function (params) {
                if (params.data.transfertCount > 0) {
                    return '<a href="' + params.data.transfertUrl + '" class="badge bg-info text-white text-decoration-none" title="عرض التحويلات"><i class="bi bi-send"></i> ' + params.data.transfertCount + '</a>';
                }
                return '<span class="text-muted">-</span>';
            }
        });

        columnDefs.push({
            headerName: 'الإجراءات',
            minWidth: canEdit ? 140 : 60,
            sortable: false,
            filter: false,
            cellRenderer: function (params) {
                var html = '<div class="btn-group btn-group-sm">'
                    + '<a class="btn btn-outline-primary" href="' + params.data.viewUrl + '" title="عرض"><i class="bi bi-eye"></i></a>';
                if (canEdit) {
                    html += '<a class="btn btn-outline-warning" href="' + params.data.editUrl + '" title="تعديل"><i class="bi bi-pencil"></i></a>'
                        + '<button type="button" class="btn btn-outline-danger" onclick="confirmDelete(\'' + params.data.cid + '\')" title="حذف"><i class="bi bi-trash"></i></button>';
                }
                html += '</div>';
                return html;
            }
        });

        var gridOptions = {
            columnDefs: columnDefs,
            rowData: rowData,
            defaultColDef: {
                resizable: true
            },
            enableRtl: true,
            animateRows: true,
            rowSelection: 'single',
            overlayNoRowsTemplate: '<div class="text-center text-muted py-5"><i class="bi bi-inbox" style="font-size: 2.5rem; opacity: 0.3;"></i><p class="mt-2 mb-0">لا توجد مراسلات</p></div>',
            onRowClicked: function (event) {
                if (event.event.target.closest('.btn-group')) return;
                var cid = event.data.cid;
                if (viewMode === 1) {
                    loadViewModal(cid);
                } else if (viewMode === 0) {
                    window.open(event.data.viewUrl, '_blank');
                } else {
                    window.location.href = event.data.viewUrl;
                }
            }
        };

        var gridDiv = document.getElementById('correspGrid');
        new agGrid.Grid(gridDiv, gridOptions);

        // Set cid when transfer/share modals are opened from the partial view
        document.getElementById('transferModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            if (btn) {
                var cidInput = btn.closest('[data-corresp-cid]');
                if (cidInput) document.getElementById('transferCid').value = cidInput.dataset.correspCid;
            }
        });
        document.getElementById('shareModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            if (btn) {
                var cidInput = btn.closest('[data-corresp-cid]');
                if (cidInput) document.getElementById('shareCid').value = cidInput.dataset.correspCid;
            }
        });

        // Share modal autocomplete
        (function () {
            var selectedContacts = [];
            var searchTimer;

            function updateContactsUI() {
                var list = $('#contactsList');
                list.empty();
                if (selectedContacts.length === 0) {
                    $('#noContactsMsg').show();
                    $('#shareSubmitBtn').prop('disabled', true);
                } else {
                    $('#noContactsMsg').hide();
                    $('#shareSubmitBtn').prop('disabled', false);
                    selectedContacts.forEach(function (c, i) {
                        list.append(
                            '<span class="badge bg-info text-dark p-2">' +
                            c.name + ' (' + c.email + ')' +
                            ' <a href="#" class="text-danger ms-1 remove-contact" data-index="' + i + '">&times;</a>' +
                            '</span>'
                        );
                    });
                }
                $('#contactsJsonInput').val(JSON.stringify(selectedContacts));
            }

            $('#contactSearch').on('input', function () {
                clearTimeout(searchTimer);
                var q = $(this).val();
                if (q.length < 2) { $('#contactSuggestions').hide(); return; }
                searchTimer = setTimeout(function () {
                    $.getJSON('/api/contacts/search', { q: q }, function (data) {
                        var sg = $('#contactSuggestions');
                        sg.empty();
                        if (data.length === 0) { sg.hide(); return; }
                        data.forEach(function (c) {
                            sg.append(
                                '<a href="#" class="list-group-item list-group-item-action suggestion-item" ' +
                                'data-name="' + c.name + '" data-email="' + c.email + '" data-phone="' + (c.phone || '') + '">' +
                                c.name + ' - ' + c.email + '</a>'
                            );
                        });
                        sg.show();
                    });
                }, 300);
            });

            $(document).on('click', '.suggestion-item', function (e) {
                e.preventDefault();
                var name = $(this).data('name'), email = $(this).data('email'), phone = $(this).data('phone');
                if (!selectedContacts.some(function (c) { return c.email === email; })) {
                    selectedContacts.push({ name: name, email: email, phone: phone });
                    updateContactsUI();
                }
                $('#contactSearch').val('');
                $('#contactSuggestions').hide();
            });

            $('#addContactBtn').on('click', function () {
                var name = $('#newContactName').val().trim();
                var email = $('#newContactEmail').val().trim();
                var phone = $('#newContactPhone').val().trim();
                if (!email) return;
                if (!selectedContacts.some(function (c) { return c.email === email; })) {
                    selectedContacts.push({ name: name || email, email: email, phone: phone });
                    updateContactsUI();
                }
                $('#newContactName').val('');
                $('#newContactEmail').val('');
                $('#newContactPhone').val('');
            });

            $(document).on('click', '.remove-contact', function (e) {
                e.preventDefault();
                selectedContacts.splice($(this).data('index'), 1);
                updateContactsUI();
            });

            $(document).on('click', function (e) {
                if (!$(e.target).closest('#contactSearch, #contactSuggestions').length) {
                    $('#contactSuggestions').hide();
                }
            });
        })();
    </script>
}
