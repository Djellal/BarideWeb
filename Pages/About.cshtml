@page
@model BarideWeb.Pages.AboutModel
@{
    ViewData["Title"] = "حول التطبيق";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card text-center" data-aos="fade-up">
            <div class="card-header card-header-custom">
                <h5 class="mb-0"><i class="bi bi-info-circle"></i> حول التطبيق</h5>
            </div>
            <div class="card-body py-5">
                <div class="mb-4">
                    <img src="~/logo-200x200.png" alt="BaridUFAS" style="width: 90px; height: 90px; border-radius: 50%; object-fit: cover;" />
                </div>
                <h3 class="fw-bold">سجل المراسلات الادارية</h3>
                <h5 class="text-muted fw-normal">BaridUFAS</h5>
                <p class="mt-3 text-secondary">تطبيق ويب لإدارة وتتبع المراسلات الإدارية</p>
                <span class="badge bg-primary bg-opacity-10 text-primary fs-6 fw-normal px-3 py-2">الإصدار 2.0 (Web)</span>

                <hr class="my-4" />

                <h6 class="fw-bold"><i class="bi bi-github"></i> المستودع</h6>
                <p>
                    <a href="https://github.com/Djellal/BarideWeb" target="_blank" class="btn btn-outline-dark btn-sm px-3">
                        <i class="bi bi-github me-1"></i> Djellal/BarideWeb
                    </a>
                </p>

                <hr class="my-4" />

                <h6 class="fw-bold"><i class="bi bi-person-fill"></i> المطور</h6>
                <p class="mb-1 fw-semibold">Djellal Elkacem</p>
                <div class="d-flex justify-content-center gap-2 flex-wrap mt-2">
                    <a href="mailto:djellal@univ-setif.dz" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-envelope-fill me-1"></i> djellal@univ-setif.dz
                    </a>
                    <a href="https://github.com/Djellal" target="_blank" class="btn btn-outline-dark btn-sm">
                        <i class="bi bi-github me-1"></i> GitHub
                    </a>
                    <a href="https://www.linkedin.com/in/djellal-elkacem" target="_blank" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-linkedin me-1"></i> LinkedIn
                    </a>
                </div>

                <hr class="my-4" />

                <p>
                    <a href="https://www.univ-setif.dz/" target="_blank" class="btn btn-outline-primary px-4">
                        <i class="bi bi-mortarboard-fill me-1"></i> جامعة سطيف
                    </a>
                </p>
                <p class="text-muted mt-3 mb-0">&copy; @DateTime.Now.Year جميع الحقوق محفوظة</p>
            </div>
        </div>
    </div>
</div>
