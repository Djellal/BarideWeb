@page
@model BarideWeb.Pages.Tenants.IndexModel
@{
    ViewData["Title"] = "إدارة المؤسسات";
}

<div class="card">
    <div class="card-header card-header-custom d-flex justify-content-between align-items-center flex-wrap">
        <h5 class="mb-0"><i class="bi bi-building"></i> إدارة المؤسسات</h5>
        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#addTenantModal">
            <i class="bi bi-plus-circle"></i> إضافة مؤسسة
        </button>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert alert-info m-3 py-2">@Model.StatusMessage</div>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered mb-0">
                <thead>
                    <tr>
                        <th>اسم المؤسسة</th>
                        <th>عدد المستخدمين</th>
                        <th>عدد المراسلات</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tenant in Model.Tenants)
                    {
                        <tr>
                            <td>@tenant.Name</td>
                            <td>@tenant.UserCount</td>
                            <td>@tenant.CorrespCount</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-outline-primary"
                                            data-bs-toggle="modal" data-bs-target="#editModal-@tenant.TenantId"
                                            title="تعديل">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-danger"
                                            data-bs-toggle="modal" data-bs-target="#deleteModal-@tenant.TenantId"
                                            title="حذف">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>

                                <!-- Edit modal -->
                                <div class="modal fade" id="editModal-@tenant.TenantId" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <form method="post" asp-page-handler="Edit">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">تعديل المؤسسة</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <input type="hidden" name="tenantId" value="@tenant.TenantId" />
                                                    <div class="mb-3">
                                                        <label class="form-label">اسم المؤسسة</label>
                                                        <input type="text" name="name" class="form-control" value="@tenant.Name" required />
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                                                    <button type="submit" class="btn btn-primary">حفظ</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <!-- Delete modal -->
                                <div class="modal fade" id="deleteModal-@tenant.TenantId" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">تأكيد الحذف</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                هل تريد حذف المؤسسة <strong>@tenant.Name</strong>؟
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">لا</button>
                                                <form method="post" asp-page-handler="Delete">
                                                    <input type="hidden" name="tenantId" value="@tenant.TenantId" />
                                                    <button type="submit" class="btn btn-danger">نعم، حذف</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add tenant modal -->
<div class="modal fade" id="addTenantModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Add">
                <div class="modal-header">
                    <h5 class="modal-title">إضافة مؤسسة جديدة</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">اسم المؤسسة</label>
                        <input type="text" name="name" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-success">إضافة</button>
                </div>
            </form>
        </div>
    </div>
</div>
