@page
@model BarideWeb.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "إدارة الأصناف";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header card-header-custom d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-tags"></i> إدارة الأصناف</h5>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        @Model.Message
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <!-- Add new category -->
                <form method="post" asp-page-handler="Add" class="mb-4">
                    <div class="input-group">
                        <input type="text" name="designation" class="form-control" placeholder="اسم الصنف الجديد..." required />
                        <button type="submit" class="btn btn-success"><i class="bi bi-plus"></i> إضافة</button>
                    </div>
                </form>

                <!-- Search -->
                <form method="get" class="mb-3">
                    <div class="input-group input-group-sm">
                        <input type="text" name="search" value="@Model.SearchText" class="form-control" placeholder="بحث..." />
                        <button type="submit" class="btn btn-outline-secondary"><i class="bi bi-search"></i></button>
                    </div>
                </form>

                <table class="table table-bordered table-hover">
                    <thead>
                        <tr>
                            <th>التصنيف</th>
                            <th style="width:250px">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in Model.Categories)
                        {
                            <tr>
                                <td>
                                    <form method="post" asp-page-handler="Edit" class="d-flex gap-2">
                                        <input type="hidden" name="catId" value="@cat.CatId" />
                                        <input type="text" name="designation" value="@cat.Designation" class="form-control form-control-sm" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></button>
                                    </form>
                                </td>
                                <td>
                                    <form method="post" asp-page-handler="Delete" onsubmit="return confirm('هل تريد فعلا حذف التصنيف: @cat.Designation ؟')">
                                        <input type="hidden" name="catId" value="@cat.CatId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> حذف</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
