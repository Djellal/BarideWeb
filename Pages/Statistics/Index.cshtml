@page
@model BarideWeb.Pages.Statistics.IndexModel
@{
    ViewData["Title"] = "الإحصائيات";
}

<div class="card mb-4">
    <div class="card-header card-header-custom d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-graph-up"></i> الإحصائيات</h5>
    </div>
    <div class="card-body">
        <!-- Summary Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-3 col-6">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <div class="mb-2"><i class="bi bi-envelope-fill text-primary" style="font-size: 2rem;"></i></div>
                        <h3 class="fw-bold mb-0">@Model.TotalCorrespondances</h3>
                        <small class="text-muted">إجمالي المراسلات</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <div class="mb-2"><i class="bi bi-file-earmark-fill text-success" style="font-size: 2rem;"></i></div>
                        <h3 class="fw-bold mb-0">@Model.TotalDocuments</h3>
                        <small class="text-muted">إجمالي الوثائق</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <div class="mb-2"><i class="bi bi-tags-fill text-warning" style="font-size: 2rem;"></i></div>
                        <h3 class="fw-bold mb-0">@Model.TotalCategories</h3>
                        <small class="text-muted">الأصناف</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <div class="mb-2"><i class="bi bi-folder-fill text-info" style="font-size: 2rem;"></i></div>
                        <h3 class="fw-bold mb-0">@Model.TotalDivers</h3>
                        <small class="text-muted">متفرقات</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Type Breakdown -->
        <div class="row g-3 mb-4">
            <div class="col-md-3 col-6">
                <div class="card h-100" style="border-right: 4px solid var(--primary) !important;">
                    <div class="card-body d-flex align-items-center gap-3">
                        <i class="bi bi-box-arrow-in-down-left text-primary" style="font-size: 1.5rem;"></i>
                        <div>
                            <h5 class="fw-bold mb-0">@Model.TotalEntrantInterne</h5>
                            <small class="text-muted">وارد داخلي</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card h-100" style="border-right: 4px solid var(--bs-info) !important;">
                    <div class="card-body d-flex align-items-center gap-3">
                        <i class="bi bi-box-arrow-in-down-right text-info" style="font-size: 1.5rem;"></i>
                        <div>
                            <h5 class="fw-bold mb-0">@Model.TotalEntrantExterne</h5>
                            <small class="text-muted">وارد خارجي</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card h-100" style="border-right: 4px solid var(--accent) !important;">
                    <div class="card-body d-flex align-items-center gap-3">
                        <i class="bi bi-box-arrow-up-right text-success" style="font-size: 1.5rem;"></i>
                        <div>
                            <h5 class="fw-bold mb-0">@Model.TotalSortantInterne</h5>
                            <small class="text-muted">صادر داخلي</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card h-100" style="border-right: 4px solid var(--bs-warning) !important;">
                    <div class="card-body d-flex align-items-center gap-3">
                        <i class="bi bi-box-arrow-up-left text-warning" style="font-size: 1.5rem;"></i>
                        <div>
                            <h5 class="fw-bold mb-0">@Model.TotalSortantExterne</h5>
                            <small class="text-muted">صادر خارجي</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Monthly Chart + Top Categories -->
<div class="row g-3 mb-4">
    <!-- Monthly Chart -->
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header card-header-custom d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-bar-chart-fill"></i> المراسلات الشهرية - @Model.CurrentYear</h6>
                <div class="d-flex gap-1">
                    <a class="btn btn-sm btn-outline-light" asp-page="/Statistics/Index" asp-route-year="@(Model.CurrentYear - 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                    <a class="btn btn-sm btn-outline-light" asp-page="/Statistics/Index" asp-route-year="@(Model.CurrentYear + 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </div>
            </div>
            <div class="card-body">
                <canvas id="monthlyChart" height="250"></canvas>
            </div>
        </div>
    </div>
    <!-- Top Categories -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header card-header-custom">
                <h6 class="mb-0"><i class="bi bi-pie-chart-fill"></i> أعلى الأصناف</h6>
            </div>
            <div class="card-body p-0">
                @if (Model.TopCategories.Any())
                {
                    var maxCount = Model.TopCategories.Max(c => c.Count);
                    <div class="list-group list-group-flush">
                        @foreach (var cat in Model.TopCategories)
                        {
                            var pct = maxCount > 0 ? (int)(cat.Count * 100.0 / maxCount) : 0;
                            <div class="list-group-item px-3 py-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-semibold" style="font-size: 0.85rem;">@cat.Name</span>
                                    <span class="badge bg-primary rounded-pill">@cat.Count</span>
                                </div>
                                <div class="progress" style="height: 5px;">
                                    <div class="progress-bar" style="width: @(pct)%;"></div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center text-muted p-4">لا توجد بيانات</div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Top Expediteurs + Type Distribution -->
<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header card-header-custom">
                <h6 class="mb-0"><i class="bi bi-people-fill"></i> أكثر المراسلين</h6>
            </div>
            <div class="card-body p-0">
                @if (Model.TopExpediteurs.Any())
                {
                    <table class="table table-striped table-hover mb-0">
                        <thead>
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>المرسل / المرسل إليه</th>
                                <th style="width: 100px;">العدد</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rank = 1; }
                            @foreach (var exp in Model.TopExpediteurs)
                            {
                                <tr>
                                    <td class="text-muted">@rank</td>
                                    <td>@exp.Name</td>
                                    <td><span class="badge bg-primary">@exp.Count</span></td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center text-muted p-4">لا توجد بيانات</div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header card-header-custom">
                <h6 class="mb-0"><i class="bi bi-pie-chart-fill"></i> توزيع الأنواع</h6>
            </div>
            <div class="card-body">
                <canvas id="typeChart" height="250"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script>
        var months = ['جانفي', 'فيفري', 'مارس', 'أفريل', 'ماي', 'جوان', 'جويلية', 'أوت', 'سبتمبر', 'أكتوبر', 'نوفمبر', 'ديسمبر'];
        var entrantData = [@string.Join(",", Model.MonthlyEntrant)];
        var sortantData = [@string.Join(",", Model.MonthlySortant)];

        new Chart(document.getElementById('monthlyChart'), {
            type: 'bar',
            data: {
                labels: months,
                datasets: [
                    {
                        label: 'الوارد',
                        data: entrantData,
                        backgroundColor: 'rgba(14, 138, 196, 0.7)',
                        borderColor: '#0e8ac4',
                        borderWidth: 1,
                        borderRadius: 4
                    },
                    {
                        label: 'الصادر',
                        data: sortantData,
                        backgroundColor: 'rgba(16, 185, 129, 0.7)',
                        borderColor: '#10b981',
                        borderWidth: 1,
                        borderRadius: 4
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'top' } },
                scales: {
                    y: { beginAtZero: true, ticks: { stepSize: 1 } }
                }
            }
        });

        new Chart(document.getElementById('typeChart'), {
            type: 'doughnut',
            data: {
                labels: ['وارد داخلي', 'وارد خارجي', 'صادر داخلي', 'صادر خارجي', 'متفرقات'],
                datasets: [{
                    data: [@Model.TotalEntrantInterne, @Model.TotalEntrantExterne, @Model.TotalSortantInterne, @Model.TotalSortantExterne, @Model.TotalDivers],
                    backgroundColor: ['#0e8ac4', '#0ea5e9', '#10b981', '#f59e0b', '#8b5cf6'],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom' } }
            }
        });
    </script>
}
