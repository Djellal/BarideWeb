@page
@model BarideWeb.Pages.Account.Users.IndexModel
@{
    ViewData["Title"] = "إدارة المستخدمين";
}

<div class="card" data-aos="fade-up">
    <div class="card-header card-header-custom d-flex justify-content-between align-items-center flex-wrap">
        <h5 class="mb-0"><i class="bi bi-people-fill"></i> إدارة المستخدمين</h5>
        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#addUserModal">
            <i class="bi bi-plus-circle"></i> إضافة مستخدم
        </button>
    </div>
    <div class="card-body p-0">
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <script>document.addEventListener('DOMContentLoaded', function() { notyf.success('@Model.StatusMessage'); });</script>
        }
        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered mb-0">
                <thead>
                    <tr>
                        <th>اسم المستخدم</th>
                        <th>الاسم الكامل</th>
                        <th>الدور</th>
                        @if (Model.IsGlobalAdmin)
                        {
                            <th>المؤسسة</th>
                        }
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.UserName</td>
                            <td>@user.FullName</td>
                            <td>
                                @(user.Role switch
                                {
                                    "Admin" => "مدير عام",
                                    "TenantAdmin" => "مدير مؤسسة",
                                    _ => "مستخدم"
                                })
                            </td>
                            @if (Model.IsGlobalAdmin)
                            {
                                <td>@(string.IsNullOrEmpty(user.TenantName) ? "—" : user.TenantName)</td>
                            }
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-outline-danger"
                                            data-bs-toggle="modal" data-bs-target="#deleteModal-@user.Id"
                                            title="حذف" disabled="@(user.UserName == "admin")">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-warning"
                                            data-bs-toggle="modal" data-bs-target="#resetModal-@user.Id"
                                            title="إعادة تعيين كلمة المرور">
                                        <i class="bi bi-key"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-primary"
                                            data-bs-toggle="modal" data-bs-target="#editModal-@user.Id"
                                            title="تعديل" disabled="@(user.UserName == "admin")">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modals outside the card to avoid transform containing block -->
@foreach (var user in Model.Users)
{
    <!-- Delete modal -->
    <div class="modal fade" id="deleteModal-@user.Id" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">تأكيد الحذف</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    هل تريد حذف المستخدم <strong>@user.UserName</strong>؟
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">لا</button>
                    <form method="post" asp-page-handler="Delete">
                        <input type="hidden" name="userId" value="@user.Id" />
                        <button type="submit" class="btn btn-danger">نعم، حذف</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Reset password modal -->
    <div class="modal fade" id="resetModal-@user.Id" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-page-handler="ResetPassword">
                    <div class="modal-header">
                        <h5 class="modal-title">إعادة تعيين كلمة المرور - @user.UserName</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="userId" value="@user.Id" />
                        <div class="mb-3">
                            <label class="form-label">كلمة المرور الجديدة</label>
                            <input type="password" name="newPassword" class="form-control" required minlength="4" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                        <button type="submit" class="btn btn-warning">تغيير</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit user modal -->
    <div class="modal fade" id="editModal-@user.Id" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-page-handler="Edit">
                    <div class="modal-header">
                        <h5 class="modal-title">تعديل المستخدم - @user.UserName</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="userId" value="@user.Id" />
                        <div class="mb-3">
                            <label class="form-label">الاسم الكامل</label>
                            <input type="text" name="fullName" class="form-control" value="@user.FullName" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">الدور</label>
                            <select name="role" class="form-select">
                                <option value="User" selected="@(user.Role == "User")">مستخدم</option>
                                <option value="TenantAdmin" selected="@(user.Role == "TenantAdmin")">مدير مؤسسة</option>
                                @if (Model.IsGlobalAdmin)
                                {
                                    <option value="Admin" selected="@(user.Role == "Admin")">مدير عام</option>
                                }
                            </select>
                        </div>
                        @if (Model.IsGlobalAdmin)
                        {
                            <div class="mb-3">
                                <label class="form-label">المؤسسة</label>
                                <select name="tenantId" class="form-select">
                                    <option value="">-- بدون مؤسسة (مدير عام) --</option>
                                    @foreach (var tenant in Model.Tenants)
                                    {
                                        <option value="@tenant.TenantId" selected="@(user.TenantId == tenant.TenantId)">@tenant.Name</option>
                                    }
                                </select>
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                        <button type="submit" class="btn btn-primary">حفظ</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- Add user modal -->
<div class="modal fade" id="addUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Add">
                <div class="modal-header">
                    <h5 class="modal-title">إضافة مستخدم جديد</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">اسم المستخدم</label>
                        <input type="text" name="username" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">الاسم الكامل</label>
                        <input type="text" name="fullName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">كلمة المرور</label>
                        <input type="password" name="password" class="form-control" required minlength="4" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">الدور</label>
                        <select name="role" class="form-select">
                            <option value="User">مستخدم</option>
                            <option value="TenantAdmin">مدير مؤسسة</option>
                            @if (Model.IsGlobalAdmin)
                            {
                                <option value="Admin">مدير عام</option>
                            }
                        </select>
                    </div>
                    @if (Model.IsGlobalAdmin)
                    {
                        <div class="mb-3">
                            <label class="form-label">المؤسسة</label>
                            <select name="tenantId" class="form-select">
                                <option value="">-- بدون مؤسسة (مدير عام) --</option>
                                @foreach (var tenant in Model.Tenants)
                                {
                                    <option value="@tenant.TenantId">@tenant.Name</option>
                                }
                            </select>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-success">إضافة</button>
                </div>
            </form>
        </div>
    </div>
</div>
