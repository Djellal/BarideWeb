<!-- Scanner Panel - Dynamsoft Dynamic Web TWAIN -->
<div class="mt-4">
    <h6 class="fw-bold"><i class="bi bi-upc-scan"></i> المسح الضوئي</h6>

    <div id="scannerPanel">
        <!-- Status: checking -->
        <div id="dwtStatus" class="alert alert-warning d-flex align-items-center gap-2">
            <div class="spinner-border spinner-border-sm" role="status"></div>
            <span>جاري تهيئة خدمة المسح الضوئي...</span>
        </div>

        <!-- Status: not installed -->
        <div id="dwtNotInstalled" class="alert alert-danger" style="display:none;">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                <strong>خدمة المسح الضوئي غير مثبّتة أو لا تعمل</strong>
            </div>
            <p class="mb-2">
                لاستخدام الماسح الضوئي، يجب تثبيت وتشغيل خدمة <strong>Dynamsoft Service</strong> على جهازك.
            </p>
            <div class="d-flex gap-2 flex-wrap">
                <a href="/Dynamic-Web-TWAIN-19.3.2/dist/dist/DynamicWebTWAINServiceSetup.msi" class="btn btn-danger btn-sm">
                    <i class="bi bi-download"></i> تحميل لنظام Windows
                </a>
                <a href="/Dynamic-Web-TWAIN-19.3.2/dist/dist/DynamicWebTWAINServiceSetup.deb" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-download"></i> تحميل لنظام Linux (deb)
                </a>
                <a href="/Dynamic-Web-TWAIN-19.3.2/dist/dist/DynamicWebTWAINServiceSetup.pkg" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-download"></i> تحميل لنظام Mac
                </a>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="location.reload()">
                    <i class="bi bi-arrow-clockwise"></i> إعادة المحاولة
                </button>
            </div>
        </div>

        <!-- Scanner controls -->
        <div id="scannerControls" style="display:none;">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">الماسح الضوئي</label>
                    <select id="scannerList" class="form-select form-select-sm"></select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">الدقة (DPI)</label>
                    <select id="scanDpi" class="form-select form-select-sm">
                        <option value="100">100</option>
                        <option value="150">150</option>
                        <option value="200" selected>200</option>
                        <option value="300">300</option>
                        <option value="600">600</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">اللون</label>
                    <select id="scanPixelMode" class="form-select form-select-sm">
                        <option value="2">ألوان</option>
                        <option value="1" selected>رمادي</option>
                        <option value="0">أبيض وأسود</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">الصيغة</label>
                    <select id="scanFormat" class="form-select form-select-sm">
                        <option value="jpg">JPG</option>
                        <option value="png">PNG</option>
                        <option value="pdf">PDF</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="button" class="btn btn-primary btn-sm" id="btnScan" disabled onclick="doScan()">
                        <i class="bi bi-upc-scan"></i> مسح ضوئي
                    </button>
                    <button type="button" class="btn btn-outline-danger btn-sm" id="btnClearScans" onclick="clearAllScans()" style="display:none;">
                        <i class="bi bi-trash"></i> مسح الكل
                    </button>
                </div>
            </div>

            <!-- DWT viewer container (hidden, used internally) -->
            <div id="dwtcontrolContainer" style="display:none;"></div>

            <!-- Scanned images preview -->
            <div id="scannedImagesContainer" class="mt-3" style="display:none;">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="form-label fw-bold mb-0">
                        الصفحات الممسوحة (<span id="scannedCount">0</span>)
                    </label>
                </div>
                <div id="scannedImagesList" class="d-flex flex-wrap gap-2"></div>
            </div>
        </div>
    </div>
</div>

<!-- Hidden input to hold scanned files for form submission -->
<input type="hidden" name="scannedFilesJson" id="scannedFilesJson" />

<script src="~/Dynamic-Web-TWAIN-19.3.2/dist/dynamsoft.webtwain.min.js"></script>
<script>
    var DWTObject = null;
    var deviceList = [];
    var scannedFiles = [];

    Dynamsoft.DWT.AutoLoad = true;
    Dynamsoft.DWT.Containers = [{ ContainerId: 'dwtcontrolContainer', Width: 0, Height: 0 }];
    Dynamsoft.DWT.ResourcesPath = '/Dynamic-Web-TWAIN-19.3.2/dist';
    Dynamsoft.DWT.ProductKey = 't0079jAAAAKeJCF5BGPKPBTrVlqojb3AFF/osDLrCocfBum0cLw/+e97O3b8j3Y+zA6N3+B0hzsl069kW0rjDzMqly6I1qioz+RP2oUoPsH0cUA==';

    function hideAllStatusPanels() {
        document.getElementById('dwtStatus').style.display = 'none';
        document.getElementById('dwtNotInstalled').style.display = 'none';
        document.getElementById('scannerControls').style.display = 'none';
    }

    Dynamsoft.DWT.RegisterEvent("OnWebTwainReady", function () {
        DWTObject = Dynamsoft.DWT.GetWebTwain('dwtcontrolContainer');
        if (DWTObject) {
            if (DWTObject.ErrorCode == 0) {
                hideAllStatusPanels();
                var el = document.getElementById('dwtStatus');
                el.style.display = '';
                el.className = 'alert alert-success d-flex align-items-center gap-2';
                el.innerHTML = '<i class="bi bi-check-circle-fill"></i> <span>خدمة المسح الضوئي متصلة</span>';
                document.getElementById('scannerControls').style.display = '';

                DWTObject.IfAllowLocalCache = true;
                DWTObject.ImageCaptureDriverType = 4;

                loadScanners();
            } else {
                hideAllStatusPanels();
                document.getElementById('dwtNotInstalled').style.display = '';
            }
        } else {
            hideAllStatusPanels();
            document.getElementById('dwtNotInstalled').style.display = '';
        }
    });

    function loadScanners() {
        if (!DWTObject) return;
        var sel = document.getElementById('scannerList');
        sel.innerHTML = '';
        sel.options.add(new Option('جاري البحث عن الماسحات...', ''));

        DWTObject.GetDevicesAsync().then(function (devices) {
            sel.options.length = 0;
            deviceList = devices;
            if (devices.length > 0) {
                for (var i = 0; i < devices.length; i++) {
                    sel.options.add(new Option(devices[i].displayName, i));
                }
                document.getElementById('btnScan').disabled = false;
            } else {
                sel.options.add(new Option('لا يوجد ماسح ضوئي', ''));
                document.getElementById('btnScan').disabled = true;
            }
        }).catch(function (exp) {
            sel.options.length = 0;
            sel.options.add(new Option('خطأ في تحميل الماسحات', ''));
            document.getElementById('btnScan').disabled = true;
        });
    }

    function doScan() {
        if (!DWTObject) return;

        var sourceIdx = parseInt(document.getElementById('scannerList').value);
        if (isNaN(sourceIdx) || sourceIdx < 0 || sourceIdx >= deviceList.length) return;

        var dpi = parseInt(document.getElementById('scanDpi').value);
        var pixelType = parseInt(document.getElementById('scanPixelMode').value);
        var imgFormat = document.getElementById('scanFormat').value;

        var btn = document.getElementById('btnScan');
        btn.disabled = true;
        btn.innerHTML = '<div class="spinner-border spinner-border-sm" role="status"></div> جاري المسح...';

        var beforeCount = DWTObject.HowManyImagesInBuffer;

        DWTObject.SelectDeviceAsync(deviceList[sourceIdx]).then(function () {
            return DWTObject.AcquireImageAsync({
                PixelType: pixelType,
                Resolution: dpi,
                IfDisableSourceAfterAcquire: true
            });
        }).then(function () {
            return DWTObject.CloseSourceAsync();
        }).then(function () {
            var totalImages = DWTObject.HowManyImagesInBuffer;
            var newCount = totalImages - beforeCount;
            if (newCount <= 0) {
                finishScan();
                return;
            }

            var processedCount = 0;
            for (var i = beforeCount; i < totalImages; i++) {
                (function (idx, pageNum) {
                    var enumType, ext, mime;
                    if (imgFormat === 'pdf') {
                        enumType = Dynamsoft.DWT.EnumDWT_ImageType.IT_PDF;
                        ext = 'pdf';
                        mime = 'application/pdf';
                    } else if (imgFormat === 'png') {
                        enumType = Dynamsoft.DWT.EnumDWT_ImageType.IT_PNG;
                        ext = 'png';
                        mime = 'image/png';
                    } else {
                        enumType = Dynamsoft.DWT.EnumDWT_ImageType.IT_JPG;
                        ext = 'jpg';
                        mime = 'image/jpeg';
                    }
                    DWTObject.ConvertToBase64(
                        [idx],
                        enumType,
                        function (result) {
                            var b64 = result.getData(0, result.getLength());
                            addScannedFile('scan_' + (scannedFiles.length + 1) + '.' + ext, 'data:' + mime + ';base64,' + b64);
                            processedCount++;
                            if (processedCount >= newCount) finishScan();
                        },
                        function (errCode, errStr) {
                            processedCount++;
                            if (processedCount >= newCount) finishScan();
                        }
                    );
                })(i, i - beforeCount + 1);
            }
        }).catch(function (exp) {
            alert('خطأ في المسح الضوئي: ' + exp.message);
            finishScan();
        });
    }

    function finishScan() {
        var btn = document.getElementById('btnScan');
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-upc-scan"></i> مسح ضوئي';
        if (DWTObject) DWTObject.RemoveAllImages();
    }

    function addScannedFile(name, dataUrl) {
        scannedFiles.push({ name: name, dataUrl: dataUrl });
        updateScannedFilesJson();
        renderScannedImages();
    }

    function updateScannedFilesJson() {
        document.getElementById('scannedFilesJson').value = JSON.stringify(scannedFiles);
    }

    function removeScannedFile(idx) {
        scannedFiles.splice(idx, 1);
        updateScannedFilesJson();
        renderScannedImages();
    }

    function clearAllScans() {
        scannedFiles = [];
        updateScannedFilesJson();
        renderScannedImages();
    }

    function renderScannedImages() {
        var container = document.getElementById('scannedImagesContainer');
        var list = document.getElementById('scannedImagesList');
        var btnClear = document.getElementById('btnClearScans');
        document.getElementById('scannedCount').textContent = scannedFiles.length;

        if (scannedFiles.length === 0) {
            container.style.display = 'none';
            btnClear.style.display = 'none';
            return;
        }
        container.style.display = '';
        btnClear.style.display = '';
        list.innerHTML = '';

        for (var i = 0; i < scannedFiles.length; i++) {
            var div = document.createElement('div');
            div.className = 'position-relative border rounded p-1';
            div.style.width = '120px';

            var ext = scannedFiles[i].name.split('.').pop().toLowerCase();
            if (ext === 'pdf') {
                div.innerHTML =
                    '<div class="text-center p-3"><i class="bi bi-file-earmark-pdf" style="font-size:2rem; color:#dc3545;"></i>' +
                    '<p class="small mb-0">' + scannedFiles[i].name + '</p></div>';
            } else {
                div.innerHTML =
                    '<img src="' + scannedFiles[i].dataUrl + '" class="img-fluid rounded" style="max-height:100px;" />' +
                    '<p class="small text-center mb-0">' + scannedFiles[i].name + '</p>';
            }

            var btnDel = document.createElement('button');
            btnDel.type = 'button';
            btnDel.className = 'btn btn-danger btn-sm position-absolute top-0 end-0 p-0';
            btnDel.style.cssText = 'width:20px; height:20px; line-height:1; font-size:0.7rem;';
            btnDel.innerHTML = '<i class="bi bi-x"></i>';
            btnDel.setAttribute('data-idx', i);
            btnDel.onclick = function () { removeScannedFile(parseInt(this.getAttribute('data-idx'))); };
            div.appendChild(btnDel);

            list.appendChild(div);
        }
    }
</script>
