<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - سجل المراسلات الادارية</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
        <div class="container-fluid">
            <span class="navbar-brand d-flex align-items-center gap-2">
                <img src="~/logo-200x200.png" alt="Logo" style="height: 40px; width: 40px; border-radius: 50%;" />
                <div>
                    <span class="fw-bold">BaridUFAS</span>
                    <small class="d-block" style="font-size: 0.7rem; opacity: 0.85;">سجل المراسلات الادارية</small>
                </div>
            </span>
        </div>
    </nav>

    <main class="container-fluid mt-4 mb-4 flex-grow-1">
        @RenderBody()
    </main>

    <footer>
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <span><i class="bi bi-envelope-fill me-1"></i> BaridUFAS - سجل المراسلات الادارية</span>
                <span>&copy; @DateTime.Now.Year جامعة سطيف</span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
