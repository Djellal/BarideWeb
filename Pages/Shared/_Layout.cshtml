<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - سجل المراسلات الادارية</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-page="/Index">
                <div class="brand-icon">
                    <i class="bi bi-envelope-fill"></i>
                </div>
                <div>
                    <span class="fw-bold">باريد</span>
                    <small class="d-block" style="font-size: 0.7rem; opacity: 0.85;">سجل المراسلات الادارية</small>
                </div>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link rounded-pill px-3" asp-page="/Index">
                            <i class="bi bi-house-door-fill"></i> الرئيسية
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link rounded-pill px-3" asp-page="/Categories/Index">
                            <i class="bi bi-tags-fill"></i> الأصناف
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link rounded-pill px-3" asp-page="/Archives/Index">
                            <i class="bi bi-archive-fill"></i> الأرشيف
                        </a>
                    </li>
                    @if (User.IsInRole("Admin") || User.IsInRole("TenantAdmin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link rounded-pill px-3" asp-page="/Account/Users/Index">
                                <i class="bi bi-people-fill"></i> المستخدمون
                            </a>
                        </li>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link rounded-pill px-3" asp-page="/Tenants/Index">
                                <i class="bi bi-building"></i> المؤسسات
                            </a>
                        </li>
                    }
                    @if (User.IsInRole("Admin") || User.IsInRole("TenantAdmin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link rounded-pill px-3" asp-page="/Parameters/Index">
                                <i class="bi bi-gear-fill"></i> الإعدادات
                            </a>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link rounded-pill px-3" asp-page="/About">
                            <i class="bi bi-info-circle-fill"></i> حول
                        </a>
                    </li>
                </ul>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-light opacity-75">
                            <i class="bi bi-person-circle"></i> @User.Identity.Name
                            @if (User.FindFirst("TenantId") != null)
                            {
                                <small class="badge bg-light text-dark ms-1">@(User.FindFirst("TenantName")?.Value ?? "")</small>
                            }
                        </span>
                        <form method="post" asp-page="/Account/Logout">
                            <button type="submit" class="btn btn-outline-light btn-sm rounded-pill">
                                <i class="bi bi-box-arrow-right"></i> خروج
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </nav>

    <main class="container-fluid mt-4 mb-4 flex-grow-1">
        @RenderBody()
    </main>

    <footer>
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <span><i class="bi bi-envelope-fill me-1"></i> باريد - سجل المراسلات الادارية</span>
                <span>&copy; @DateTime.Now.Year جامعة سطيف</span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
