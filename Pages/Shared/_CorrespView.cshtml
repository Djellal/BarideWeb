@using BarideWeb.Models
@model CorrespViewData

<div class="card">
    <div class="card-header card-header-custom d-flex justify-content-between align-items-center flex-wrap">
        <h5 class="mb-0"><i class="bi bi-envelope-open"></i> مراسلة رقم @Model.Corresp.Num - @Model.TypeLabel</h5>
        @if (User.IsInRole("Admin") || User.IsInRole("TenantAdmin"))
        {
            <a class="btn btn-warning btn-sm" asp-page="/Correspondances/Edit" asp-route-id="@Model.Corresp.Cid">
                <i class="bi bi-pencil"></i> تعديل
            </a>
        }
    </div>
    <div class="card-body">
        <!-- Corresp details -->
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label fw-bold text-secondary"><i class="bi bi-hash"></i> الرقم</label>
                <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.Num</div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-secondary"><i class="bi bi-hash"></i> الرقم الداخلي</label>
                <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.NumInterne</div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-secondary"><i class="bi bi-calendar3"></i> تاريخ المراسلة</label>
                <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.DateCorresp.ToString("d")</div>
            </div>
            @if (Model.Corresp.Type == TypeCorresp.Entrant_Interne || Model.Corresp.Type == TypeCorresp.Entrant_Externe)
            {
                <div class="col-md-3">
                    <label class="form-label fw-bold text-secondary"><i class="bi bi-calendar-check"></i> تاريخ الوصول</label>
                    <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.DateArrivDepart.ToString("d")</div>
                </div>
            }
        </div>

        <div class="row g-3 mt-1">
            <div class="col-md-4">
                <label class="form-label fw-bold text-secondary"><i class="bi bi-person"></i> @Model.ExpedLabel</label>
                <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.Expediteur</div>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-secondary"><i class="bi bi-chat-left-text"></i> الموضوع</label>
                <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.Objet</div>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-secondary"><i class="bi bi-tag"></i> الصنف</label>
                <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@(Model.Corresp.Categ?.Designation ?? "—")</div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Corresp.Observation))
        {
            <div class="row g-3 mt-1">
                <div class="col-md-12">
                    <label class="form-label fw-bold text-secondary"><i class="bi bi-sticky"></i> ملاحظة</label>
                    <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.Observation</div>
                </div>
            </div>
        }

        <!-- Documents panel -->
        <div class="mt-4">
            <h6 class="fw-bold mb-3"><i class="bi bi-paperclip"></i> الوثائق المرفقة</h6>
            @if (Model.Documents.Any())
            {
                <div class="row g-0 border rounded overflow-hidden" style="min-height: 400px;">
                    <!-- Documents list (side panel) -->
                    <div class="col-md-4 border-start" style="background: #f1f5f9;">
                        <div class="p-2 border-bottom" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);">
                            <small class="text-white fw-bold"><i class="bi bi-folder2-open"></i> قائمة الوثائق (@Model.Documents.Count)</small>
                        </div>
                        <div class="list-group list-group-flush doc-list">
                            @foreach (var doc in Model.Documents)
                            {
                                var ext = !string.IsNullOrEmpty(doc.FileName) ? doc.FileName.Split('.').Last().ToLower() : "";
                                var icon = ext switch {
                                    "pdf" => "bi-file-earmark-pdf text-danger",
                                    "jpg" or "jpeg" or "png" or "gif" or "bmp" or "webp" => "bi-file-earmark-image text-success",
                                    "doc" or "docx" => "bi-file-earmark-word text-primary",
                                    "xls" or "xlsx" => "bi-file-earmark-excel text-success",
                                    _ => "bi-file-earmark text-secondary"
                                };
                                <button type="button"
                                        class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-2 px-3 doc-item"
                                        @if (!string.IsNullOrEmpty(doc.FileName)) {
                                            <text>onclick="selectDocument(this, '/uploads/@doc.FileName')"</text>
                                        }>
                                    <i class="bi @icon" style="font-size: 1.2rem;"></i>
                                    <div class="flex-grow-1 text-truncate">
                                        <div class="fw-semibold text-truncate" style="font-size: 0.85rem;">@(doc.Designation ?? "بدون وصف")</div>
                                        @if (!string.IsNullOrEmpty(doc.FileName))
                                        {
                                            <small class="text-muted text-uppercase">@ext</small>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(doc.FileName))
                                    {
                                        <a href="/uploads/@doc.FileName" target="_blank" class="btn btn-sm btn-outline-secondary border-0" onclick="event.stopPropagation()" title="فتح في نافذة جديدة">
                                            <i class="bi bi-box-arrow-up-left"></i>
                                        </a>
                                    }
                                </button>
                            }
                        </div>
                    </div>
                    <!-- Preview panel -->
                    <div class="col-md-8 d-flex flex-column">
                        <div class="p-2 border-bottom" style="background: #e2e8f0;">
                            <small class="text-secondary fw-bold"><i class="bi bi-eye"></i> معاينة الوثيقة</small>
                        </div>
                        <div class="doc-preview flex-grow-1 d-flex align-items-center justify-content-center" style="background: #fafbfc;">
                            <div class="text-center text-muted p-4">
                                <i class="bi bi-file-earmark-richtext" style="font-size: 3rem; opacity: 0.15;"></i>
                                <p class="mt-2 mb-0" style="font-size: 0.9rem;">اختر وثيقة من القائمة لمعاينتها</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="border rounded p-4 text-center text-muted" style="background: #f8fafc;">
                    <i class="bi bi-folder" style="font-size: 2rem; opacity: 0.2;"></i>
                    <p class="mt-2 mb-0">لا توجد وثائق مرفقة</p>
                </div>
            }
        </div>

        @if (!Model.IsModal)
        {
            <div class="mt-4">
                <a class="btn btn-secondary" asp-page="/Index" asp-route-type="@((int)Model.Corresp.Type!)">
                    <i class="bi bi-arrow-right"></i> رجوع
                </a>
            </div>
        }
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var first = document.querySelector('.doc-list .doc-item[onclick]');
        if (first) first.click();
    });

    if (typeof selectDocument === 'undefined') {
        function selectDocument(el, url) {
            var container = el.closest('.row');
            container.querySelectorAll('.doc-item').forEach(function (item) {
                item.classList.remove('active');
            });
            el.classList.add('active');

            var viewer = container.querySelector('.doc-preview');
            if (!viewer) return;
            var ext = url.split('.').pop().toLowerCase();
            if (ext === 'pdf') {
                viewer.innerHTML = '<iframe src="' + url + '" width="100%" height="100%" style="min-height:400px; border:none;"></iframe>';
            } else if (['jpg', 'jpeg', 'png', 'gif', 'bmp', 'webp'].indexOf(ext) >= 0) {
                viewer.innerHTML = '<div class="p-3 text-center"><img src="' + url + '" class="img-fluid rounded shadow-sm" style="max-height:500px;" /></div>';
            } else {
                viewer.innerHTML = '<div class="text-center p-4"><i class="bi bi-file-earmark-arrow-down" style="font-size:3rem; color:var(--primary);"></i>'
                    + '<p class="mt-2">لا يمكن معاينة هذا الملف</p>'
                    + '<a href="' + url + '" target="_blank" class="btn btn-primary btn-sm"><i class="bi bi-download"></i> تحميل الملف</a></div>';
            }
        }
    }
</script>

<style>
    .doc-list .doc-item {
        border-radius: 0 !important;
        border-left: 3px solid transparent;
        transition: all 0.15s ease;
        background: transparent;
    }
    .doc-list .doc-item:hover {
        background: #e2e8f0;
        border-left-color: var(--primary);
    }
    .doc-list .doc-item.active {
        background: var(--primary-light) !important;
        border-left-color: var(--primary) !important;
        color: var(--primary);
    }
</style>
