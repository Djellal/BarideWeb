@page
@model BarideWeb.Pages.Transferts.IndexModel
@using BarideWeb.Models
@{
    ViewData["Title"] = "التحويلات";
}

<div class="card">
    <div class="card-header card-header-custom d-flex justify-content-between align-items-center flex-wrap">
        <h5 class="mb-0"><i class="bi bi-arrow-left-right"></i> التحويلات</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered mb-0">
                <thead>
                    <tr>
                        <th>المراسلة</th>
                        <th>المرسل</th>
                        <th>المرسل إليه</th>
                        <th>التاريخ</th>
                        <th>ملاحظة</th>
                        <th>الحالة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Transferts)
                    {
                        <tr class="@(!t.IsViewed ? "table-warning" : "")">
                            <td>
                                <a asp-page="/Correspondances/View" asp-route-id="@t.Cid">@(t.Corresp?.Num ?? "-")</a>
                            </td>
                            <td>@(t.Sender?.FullName ?? "-")</td>
                            <td>@(t.Receiver?.FullName ?? "-")</td>
                            <td>@t.DateTransfert.ToString("yyyy-MM-dd")</td>
                            <td>@(t.Note ?? "-")</td>
                            <td>
                                @if (t.IsViewed)
                                {
                                    <span class="badge bg-success">تمت المعاينة</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">جديد</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    @if (!t.IsViewed)
                                    {
                                        <form method="post" asp-page-handler="MarkViewed" class="d-inline">
                                            <input type="hidden" name="id" value="@t.TransfertId" />
                                            <button type="submit" class="btn btn-outline-success" title="تمت المعاينة">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (User.IsInRole("Admin") || User.IsInRole("TenantAdmin"))
                                    {
                                        <button type="button" class="btn btn-outline-warning"
                                                data-bs-toggle="modal" data-bs-target="#editModal-@t.TransfertId"
                                                title="تعديل الملاحظة">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button type="button" class="btn btn-outline-danger"
                                                data-bs-toggle="modal" data-bs-target="#deleteModal-@t.TransfertId"
                                                title="حذف">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>

                                @if (User.IsInRole("Admin") || User.IsInRole("TenantAdmin"))
                                {
                                    <!-- Edit modal -->
                                    <div class="modal fade" id="editModal-@t.TransfertId" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <form method="post" asp-page-handler="Edit">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">تعديل الملاحظة</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <input type="hidden" name="id" value="@t.TransfertId" />
                                                        <div class="mb-3">
                                                            <label class="form-label">ملاحظة</label>
                                                            <textarea name="note" class="form-control" rows="3">@t.Note</textarea>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                                                        <button type="submit" class="btn btn-warning">حفظ</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Delete modal -->
                                    <div class="modal fade" id="deleteModal-@t.TransfertId" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">تأكيد الحذف</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    هل تريد حذف هذا التحويل؟
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">لا</button>
                                                    <form method="post" asp-page-handler="Delete">
                                                        <input type="hidden" name="id" value="@t.TransfertId" />
                                                        <button type="submit" class="btn btn-danger">نعم، حذف</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
