@page "{id:guid}"
@model BarideWeb.Pages.Correspondances.EditModel
@{
    ViewData["Title"] = "مراسلة رقم " + Model.Corresp.Num;
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card">
            <div class="card-header card-header-custom">
                <h5 class="mb-0"><i class="bi bi-envelope-open"></i> مراسلة رقم @Model.Corresp.Num - @Model.TypeLabel</h5>
            </div>
            <div class="card-body">
                <form method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Corresp.Cid" />
                    <input type="hidden" asp-for="Corresp.Type" />
                    <input type="hidden" asp-for="Corresp.CorrespRep" />

                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">الرقم</label>
                            <input type="text" asp-for="Corresp.Num" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">الرقم الداخلي</label>
                            <input type="text" asp-for="Corresp.NumInterne" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">تاريخ المراسلة</label>
                            <input type="date" asp-for="Corresp.DateCorresp" class="form-control" />
                        </div>
                        @if (Model.Corresp.Type == TypeCorresp.Entrant_Interne || Model.Corresp.Type == TypeCorresp.Entrant_Externe)
                        {
                            <div class="col-md-3">
                                <label class="form-label fw-bold">تاريخ الوصول</label>
                                <input type="date" asp-for="Corresp.DateArrivDepart" class="form-control" />
                            </div>
                        }
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">@Model.ExpedLabel</label>
                            <input type="text" asp-for="Corresp.Expediteur" class="form-control" list="expedList" />
                            <datalist id="expedList">
                                @foreach (var e in Model.ExpedSuggestions)
                                {
                                    <option value="@e" />
                                }
                            </datalist>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">الموضوع</label>
                            <input type="text" asp-for="Corresp.Objet" class="form-control" list="objetList" />
                            <datalist id="objetList">
                                @foreach (var o in Model.ObjetSuggestions)
                                {
                                    <option value="@o" />
                                }
                            </datalist>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">الصنف</label>
                            <select asp-for="Corresp.CatId" class="form-select" asp-items="Model.CategoriesList" required>
                                <option value="">-- اختر الصنف --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">ملاحظة</label>
                            <textarea asp-for="Corresp.Observation" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <!-- Existing documents -->
                    <div class="mt-4">
                        <h6 class="fw-bold"><i class="bi bi-paperclip"></i> الوثائق المرفقة</h6>
                        @if (Model.Documents.Any())
                        {
                            <table class="table table-sm table-bordered">
                                <thead>
                                    <tr>
                                        <th>الوصف</th>
                                        <th>الملف</th>
                                        <th>الإجراءات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var doc in Model.Documents)
                                    {
                                        <tr>
                                            <td>@doc.Designation</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(doc.FileName))
                                                {
                                                    <a href="/uploads/@doc.FileName" target="_blank" class="btn btn-sm btn-outline-info">
                                                        <i class="bi bi-eye"></i> عرض
                                                    </a>
                                                }
                                            </td>
                                            <td>
                                                <button type="submit" asp-page-handler="DeleteDoc" name="docId" value="@doc.DocId"
                                                        class="btn btn-sm btn-outline-danger"
                                                        onclick="event.preventDefault(); var btn=this; swalConfirm('هل تريد فعلا حذف هذه الوثيقة ؟', function(){ btn.removeAttribute('onclick'); btn.click(); });">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">لا توجد وثائق مرفقة</p>
                        }

                        <label class="form-label mt-2">إضافة وثائق جديدة</label>
                        <input type="file" name="newFiles" multiple class="form-control" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" id="fileInput" onchange="previewFiles(this)" />
                        <div id="filePreviewArea" class="mt-3" style="display:none;">
                            <div id="filePreviewList" class="d-flex flex-wrap gap-2 mb-2"></div>
                            <div id="filePreviewViewer" class="border rounded mt-2" style="display:none;"></div>
                        </div>
                    </div>

                    <!-- Scanner -->
                    <partial name="_ScannerPanel" />

                    <!-- PDF Viewer -->
                    @if (Model.Documents.Any(d => d.FileName != null && d.FileName.EndsWith(".pdf")))
                    {
                        <div class="mt-4">
                            <h6 class="fw-bold"><i class="bi bi-file-earmark-pdf"></i> معاينة الوثيقة</h6>
                            @{
                                var firstPdf = Model.Documents.FirstOrDefault(d => d.FileName != null && d.FileName.EndsWith(".pdf"));
                            }
                            @if (firstPdf != null)
                            {
                                <iframe src="/uploads/@firstPdf.FileName" width="100%" height="500" class="border rounded"></iframe>
                            }
                        </div>
                    }

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> حفظ التعديلات
                        </button>
                        <a class="btn btn-secondary" asp-page="/Index" asp-route-type="@((int)Model.Corresp.Type!)">
                            <i class="bi bi-arrow-right"></i> رجوع
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function previewFiles(input) {
    var area = document.getElementById('filePreviewArea');
    var list = document.getElementById('filePreviewList');
    var viewer = document.getElementById('filePreviewViewer');
    list.innerHTML = '';
    viewer.style.display = 'none';
    if (!input.files || input.files.length === 0) { area.style.display = 'none'; return; }
    area.style.display = '';
    for (var i = 0; i < input.files.length; i++) {
        (function(file, idx) {
            var ext = file.name.split('.').pop().toLowerCase();
            var div = document.createElement('div');
            div.className = 'border rounded p-2 text-center';
            div.style.cssText = 'width:120px; cursor:pointer;';
            div.onclick = function() { showFilePreview(file, ext); };
            if (['jpg','jpeg','png','gif','bmp','webp'].indexOf(ext) >= 0) {
                var img = document.createElement('img');
                img.style.cssText = 'max-height:80px; max-width:100%;';
                img.className = 'rounded';
                var reader = new FileReader();
                reader.onload = function(e) { img.src = e.target.result; };
                reader.readAsDataURL(file);
                div.appendChild(img);
            } else if (ext === 'pdf') {
                div.innerHTML = '<i class="bi bi-file-earmark-pdf" style="font-size:2.5rem; color:#dc3545;"></i>';
            } else {
                div.innerHTML = '<i class="bi bi-file-earmark" style="font-size:2.5rem; color:var(--primary);"></i>';
            }
            var name = document.createElement('p');
            name.className = 'small mb-0 mt-1 text-truncate';
            name.title = file.name;
            name.textContent = file.name;
            div.appendChild(name);
            list.appendChild(div);
            if (idx === 0) showFilePreview(file, ext);
        })(input.files[i], i);
    }
}
function showFilePreview(file, ext) {
    var viewer = document.getElementById('filePreviewViewer');
    viewer.style.display = '';
    if (ext === 'pdf') {
        var url = URL.createObjectURL(file);
        viewer.innerHTML = '<iframe src="' + url + '" width="100%" height="500" style="border:none;"></iframe>';
    } else if (['jpg','jpeg','png','gif','bmp','webp'].indexOf(ext) >= 0) {
        var reader = new FileReader();
        reader.onload = function(e) {
            viewer.innerHTML = '<div class="p-3 text-center"><img src="' + e.target.result + '" class="img-fluid rounded shadow-sm" style="max-height:500px;" /></div>';
        };
        reader.readAsDataURL(file);
    } else {
        viewer.innerHTML = '<div class="text-center p-4 text-muted"><i class="bi bi-file-earmark" style="font-size:3rem;"></i><p class="mt-2">لا يمكن معاينة هذا الملف</p></div>';
    }
}

// Override scanner addScannedFile to also show preview
document.addEventListener('DOMContentLoaded', function() {
    if (typeof addScannedFile === 'function') {
        var orig = addScannedFile;
        addScannedFile = function(name, dataUrl) {
            orig(name, dataUrl);
            showScannedPreview(name, dataUrl);
        };
    }
});
function showScannedPreview(name, dataUrl) {
    var viewer = document.getElementById('filePreviewViewer');
    var area = document.getElementById('filePreviewArea');
    area.style.display = '';
    viewer.style.display = '';
    var ext = name.split('.').pop().toLowerCase();
    if (ext === 'pdf') {
        viewer.innerHTML = '<iframe src="' + dataUrl + '" width="100%" height="500" style="border:none;"></iframe>';
    } else {
        viewer.innerHTML = '<div class="p-3 text-center"><img src="' + dataUrl + '" class="img-fluid rounded shadow-sm" style="max-height:500px;" /></div>';
    }
}
</script>
}
