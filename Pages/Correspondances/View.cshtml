@page "{id:guid}"
@model BarideWeb.Pages.Correspondances.ViewModel
@{
    ViewData["Title"] = "مراسلة رقم " + Model.Corresp.Num;
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card">
            <div class="card-header card-header-custom d-flex justify-content-between align-items-center flex-wrap">
                <h5 class="mb-0"><i class="bi bi-envelope-open"></i> مراسلة رقم @Model.Corresp.Num - @Model.TypeLabel</h5>
                <a class="btn btn-warning btn-sm" asp-page="/Correspondances/Edit" asp-route-id="@Model.Corresp.Cid">
                    <i class="bi bi-pencil"></i> تعديل
                </a>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">الرقم</label>
                        <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.Num</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">الرقم الداخلي</label>
                        <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.NumInterne</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">تاريخ المراسلة</label>
                        <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.DateCorresp.ToString("d")</div>
                    </div>
                    @if (Model.Corresp.Type == TypeCorresp.Entrant_Interne || Model.Corresp.Type == TypeCorresp.Entrant_Externe)
                    {
                        <div class="col-md-3">
                            <label class="form-label fw-bold">تاريخ الوصول</label>
                            <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.DateArrivDepart.ToString("d")</div>
                        </div>
                    }
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">@Model.ExpedLabel</label>
                        <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.Expediteur</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">الموضوع</label>
                        <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.Objet</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">الصنف</label>
                        <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@(Model.Corresp.Categ?.Designation ?? "—")</div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Corresp.Observation))
                {
                    <div class="row g-3 mt-1">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">ملاحظة</label>
                            <div class="form-control-plaintext border rounded px-2 py-1 bg-light">@Model.Corresp.Observation</div>
                        </div>
                    </div>
                }

                <!-- Documents -->
                <div class="mt-4">
                    <h6 class="fw-bold"><i class="bi bi-paperclip"></i> الوثائق المرفقة</h6>
                    @if (Model.Documents.Any())
                    {
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>الوصف</th>
                                    <th>الملف</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in Model.Documents)
                                {
                                    <tr>
                                        <td>@doc.Designation</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(doc.FileName))
                                            {
                                                <a href="/uploads/@doc.FileName" target="_blank" class="btn btn-sm btn-outline-info">
                                                    <i class="bi bi-eye"></i> عرض
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">لا توجد وثائق مرفقة</p>
                    }
                </div>

                <!-- PDF Viewer -->
                @if (Model.Documents.Any(d => d.FileName != null && d.FileName.EndsWith(".pdf")))
                {
                    <div class="mt-4">
                        <h6 class="fw-bold"><i class="bi bi-file-earmark-pdf"></i> معاينة الوثيقة</h6>
                        @{
                            var firstPdf = Model.Documents.FirstOrDefault(d => d.FileName != null && d.FileName.EndsWith(".pdf"));
                        }
                        @if (firstPdf != null)
                        {
                            <iframe src="/uploads/@firstPdf.FileName" width="100%" height="500" class="border rounded"></iframe>
                        }
                    </div>
                }

                <div class="mt-4">
                    <a class="btn btn-secondary" asp-page="/Index" asp-route-type="@((int)Model.Corresp.Type!)">
                        <i class="bi bi-arrow-right"></i> رجوع
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
