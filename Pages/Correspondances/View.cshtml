@page "{id:guid}"
@model BarideWeb.Pages.Correspondances.ViewModel
@using BarideWeb.Models
@{
    ViewData["Title"] = "مراسلة رقم " + Model.Corresp.Num;
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <partial name="_CorrespView" model="new CorrespViewData {
            Corresp = Model.Corresp,
            Documents = Model.Documents,
            TypeLabel = Model.TypeLabel,
            ExpedLabel = Model.ExpedLabel,
            IsModal = false
        }" />

        <!-- Transfer modal -->
        <div class="modal fade" id="transferModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form method="post" asp-page-handler="Transfer">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="bi bi-send"></i> تحويل المراسلة</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <input type="hidden" name="cid" value="@Model.Corresp.Cid" />
                            <div class="mb-3">
                                <label class="form-label">المرسل إليهم</label>
                                <select id="transferUserSelect" name="receiverIds" multiple placeholder="اكتب اسم المستخدم..."></select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">ملاحظة</label>
                                <textarea name="note" class="form-control" rows="3"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                            <button type="submit" class="btn btn-info text-white">تحويل</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <!-- Share modal -->
        <div class="modal fade" id="shareModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form method="post" asp-page-handler="Share" id="shareForm">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="bi bi-share"></i> إرسال رابط المراسلة</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <input type="hidden" name="cid" value="@Model.Corresp.Cid" />
                            <input type="hidden" name="contactsJson" id="contactsJsonInput" />
                            <div class="mb-3">
                                <label class="form-label">جهات الاتصال</label>
                                <select id="shareContactSelect" multiple placeholder="اكتب الاسم أو البريد..."></select>
                                <small class="text-muted">اكتب بريد إلكتروني جديد واضغط Enter لإضافته</small>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-envelope"></i> إرسال
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Email Error Modal -->
<div class="modal fade" id="emailErrorModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle"></i> خطأ في الإرسال</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" dir="rtl">
                <p>فشل إرسال البريد الإلكتروني إلى العناوين التالية:</p>
                <ul id="emailErrorList"></ul>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Transfer modal - tom-select for users
    new TomSelect('#transferUserSelect', {
        valueField: 'id',
        labelField: 'fullName',
        searchField: ['fullName', 'userName'],
        plugins: ['remove_button'],
        load: function (query, callback) {
            if (query.length < 2) return callback();
            fetch('/api/users/search?q=' + encodeURIComponent(query))
                .then(function (r) { return r.json(); })
                .then(function (data) { callback(data); })
                .catch(function () { callback(); });
        },
        render: {
            option: function (item) {
                return '<div>' + item.fullName + ' <small class="text-muted">(' + item.userName + ')</small></div>';
            },
            item: function (item) {
                return '<div>' + item.fullName + ' (' + item.userName + ')</div>';
            }
        }
    });

    // Share modal - tom-select for contacts with create
    var shareSelect = new TomSelect('#shareContactSelect', {
        valueField: 'email',
        labelField: 'name',
        searchField: ['name', 'email'],
        plugins: ['remove_button'],
        create: function (input) {
            return { name: input, email: input, phone: '' };
        },
        load: function (query, callback) {
            if (query.length < 2) return callback();
            fetch('/api/contacts/search?q=' + encodeURIComponent(query))
                .then(function (r) { return r.json(); })
                .then(function (data) { callback(data); })
                .catch(function () { callback(); });
        },
        render: {
            option: function (item) {
                return '<div>' + item.name + ' <small class="text-muted">' + item.email + '</small></div>';
            },
            item: function (item) {
                return '<div>' + item.name + ' (' + item.email + ')</div>';
            }
        },
        onItemAdd: function () { updateContactsJson(); },
        onItemRemove: function () { updateContactsJson(); }
    });

    function updateContactsJson() {
        var items = shareSelect.items.map(function (email) {
            var opt = shareSelect.options[email];
            return { name: opt.name || email, email: email, phone: opt.phone || '' };
        });
        document.getElementById('contactsJsonInput').value = JSON.stringify(items);
    }

    // Submit share form via AJAX and show errors in modal
    document.getElementById('shareForm').addEventListener('submit', function (e) {
        e.preventDefault();
        var form = this;
        var formData = new FormData(form);
        var submitBtn = form.querySelector('button[type="submit"]');
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> جاري الإرسال...';

        fetch(form.action, {
            method: 'POST',
            body: formData
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.success) {
                window.location.reload();
            } else {
                var list = document.getElementById('emailErrorList');
                list.innerHTML = '';
                data.errors.forEach(function (err) {
                    var li = document.createElement('li');
                    li.textContent = err;
                    list.appendChild(li);
                });
                bootstrap.Modal.getInstance(document.getElementById('shareModal')).hide();
                new bootstrap.Modal(document.getElementById('emailErrorModal')).show();
            }
        })
        .catch(function () {
            var list = document.getElementById('emailErrorList');
            list.innerHTML = '<li>حدث خطأ غير متوقع أثناء الإرسال</li>';
            bootstrap.Modal.getInstance(document.getElementById('shareModal')).hide();
            new bootstrap.Modal(document.getElementById('emailErrorModal')).show();
        })
        .finally(function () {
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="bi bi-envelope"></i> إرسال';
        });
    });
</script>
}
