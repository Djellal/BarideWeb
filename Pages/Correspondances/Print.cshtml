@page
@model BarideWeb.Pages.Correspondances.PrintModel
@{
    ViewData["Title"] = Model.ReportTitle;
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>@Model.ReportTitle</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <style>
        body { font-family: 'Segoe UI', Tahoma, Arial, sans-serif; }
        @@media print {
            .no-print { display: none !important; }
            body { margin: 0; }
        }
        .report-header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #333;
            padding-bottom: 10px;
        }
        table th {
            background-color: #119eda !important;
            color: white !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
    </style>
</head>
<body>
    <div class="container mt-3">
        <div class="no-print mb-3 d-flex gap-2">
            <button onclick="window.print()" class="btn btn-primary btn-sm">
                <i class="bi bi-printer"></i> طباعة
            </button>
            <a href="javascript:history.back()" class="btn btn-secondary btn-sm">رجوع</a>
        </div>

        <div class="report-header">
            <h3>@Model.ReportTitle</h3>
            <p class="text-muted">@DateTime.Now.ToString("d")</p>
        </div>

        <table class="table table-bordered table-sm">
            <thead>
                <tr>
                    <th>الرقم</th>
                    <th>الرقم الداخلي</th>
                    <th>تاريخ المراسلة</th>
                    <th>تاريخ الوصول</th>
                    <th>@Model.ExpedLabel</th>
                    <th>الموضوع</th>
                    <th>الصنف</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Correspondances)
                {
                    <tr>
                        <td>@c.Num</td>
                        <td>@c.NumInterne</td>
                        <td>@c.DateCorresp.ToString("d")</td>
                        <td>@c.DateArrivDepart.ToString("d")</td>
                        <td>@c.Expediteur</td>
                        <td>@c.Objet</td>
                        <td>@c.Categ?.Designation</td>
                    </tr>
                }
            </tbody>
        </table>

        <p class="text-muted text-center mt-3">عدد المراسلات: @Model.Correspondances.Count</p>
    </div>
</body>
</html>
